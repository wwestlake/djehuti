@namespace Djehuti.Architect.Layout
@inject AuthState Auth
@inject NavigationManager Nav
@implements IDisposable

<div class="arch-auth-corner">
    @if (Auth.Loading)
    {
        <span class="arch-auth-loading"></span>
    }
    else if (Auth.CurrentUser is not null)
    {
        <div class="arch-auth-chip-wrap">
            <button type="button" class="arch-auth-chip" @onclick="ToggleMenu">
                <span class="arch-auth-avatar">@Initial</span>
                <span class="arch-auth-name">@(Auth.CurrentUser.DisplayName ?? Auth.CurrentUser.Email)</span>
            </button>
            @if (_menuOpen)
            {
                <div class="arch-auth-menu-backdrop" @onclick="() => _menuOpen = false"></div>
                <div class="arch-auth-menu">
                    <div class="arch-auth-menu-header">@(Auth.CurrentUser.DisplayName ?? Auth.CurrentUser.Email)</div>
                    <a class="arch-auth-menu-item" href="https://lagdaemon.com/profile">View site profile</a>
                    <button type="button" class="arch-auth-menu-item arch-auth-menu-danger" @onclick="SignOut">Sign out</button>
                </div>
            }
        </div>
    }
    else
    {
        <a class="arch-auth-signin" href="https://lagdaemon.com/">Sign in</a>
    }
</div>

@code {
    private bool _menuOpen;

    private string Initial => (Auth.CurrentUser?.DisplayName ?? Auth.CurrentUser?.Email ?? "?").Trim() is { Length: > 0 } s ? s[..1].ToUpperInvariant() : "?";

    protected override async Task OnInitializedAsync()
    {
        Auth.Changed += StateHasChanged;
        await Auth.EnsureLoadedAsync();
    }

    private void ToggleMenu() => _menuOpen = !_menuOpen;

    private async Task SignOut()
    {
        _menuOpen = false;
        await Auth.SignOutAsync();
        Nav.NavigateTo(Nav.Uri, forceLoad: true);
    }

    public void Dispose() => Auth.Changed -= StateHasChanged;
}
