@namespace Djehuti.Architect.Components
@inject IJSRuntime JS
@inject NavigationManager Nav
@implements IAsyncDisposable

<div id="@_elementId" class="arch-diagram"></div>

@code {
    [Parameter, EditorRequired] public string DiagramSource { get; set; } = "";

    private readonly string _elementId = $"arch-diagram-{Guid.NewGuid():N}";
    private IJSObjectReference? _module;
    private string _lastRenderedSource = "";

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (DiagramSource == _lastRenderedSource && !firstRender) return;
        _lastRenderedSource = DiagramSource;

        if (string.IsNullOrWhiteSpace(DiagramSource)) return;

        try
        {
            // Relative import specifiers have previously resolved incorrectly
            // from child components (see Teacher's MusicStaff.razor) -- build
            // an absolute URL from NavigationManager.BaseUri to sidestep it.
            _module ??= await JS.InvokeAsync<IJSObjectReference>("import", new Uri(new Uri(Nav.BaseUri), "js/diagram-interop.js").ToString());
            await _module.InvokeVoidAsync("renderDiagram", _elementId, DiagramSource);
        }
        catch (Exception ex)
        {
            _module = null; // stale cached module across a deploy -- retry next render
            try { await JS.InvokeVoidAsync("console.error", $"MermaidDiagram render failed: {ex.GetType().Name}: {ex.Message}"); }
            catch { /* logging itself failing isn't worth cascading over */ }
        }
    }

    public async ValueTask DisposeAsync()
    {
        if (_module is not null)
        {
            try { await _module.DisposeAsync(); }
            catch (JSDisconnectedException) { /* circuit already gone */ }
        }
    }
}
