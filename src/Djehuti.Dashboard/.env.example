# API Configuration
VITE_API_BASE=http://localhost:5087

# hCaptcha Configuration
VITE_HCAPTCHA_SITE_KEY=your_hcaptcha_site_key_here

# OAuth Configuration (Google)
VITE_GOOGLE_OAUTH_CLIENT_ID=your_google_oauth_client_id_here

# OAuth Configuration (GitHub)
VITE_GITHUB_OAUTH_CLIENT_ID=your_github_oauth_client_id_here

# S3 Media Storage (server-side env vars — not VITE_ prefixed)
# S3_BUCKET=your-bucket-name
# S3_REGION=us-east-1
# AWS credentials should be set via IAM role on the server, or:
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
