@namespace Djehuti.Teacher.Layout
@inject HttpClient Http
@inject NavigationManager Nav

<div class="teacher-auth-corner">
    @if (_loading)
    {
        <span class="teacher-auth-loading"></span>
    }
    else if (_me is not null)
    {
        <div class="teacher-auth-chip-wrap">
            <button type="button" class="teacher-auth-chip" @onclick="ToggleMenu">
                <span class="teacher-auth-avatar">@Initial</span>
                <span class="teacher-auth-name">@(_me.DisplayName ?? _me.Email)</span>
            </button>
            @if (_menuOpen)
            {
                <div class="teacher-auth-menu-backdrop" @onclick="() => _menuOpen = false"></div>
                <div class="teacher-auth-menu">
                    <div class="teacher-auth-menu-header">@(_me.DisplayName ?? _me.Email)</div>
                    <a class="teacher-auth-menu-item" href="https://lagdaemon.com/profile">View site profile</a>
                    <button type="button" class="teacher-auth-menu-item teacher-auth-menu-danger" @onclick="SignOut">Sign out</button>
                </div>
            }
        </div>
    }
    else
    {
        <a class="teacher-auth-signin" href="/">Sign in</a>
    }
</div>

@code {
    private bool _loading = true;
    private bool _menuOpen;
    private MeResponse? _me;

    private string Initial => (_me?.DisplayName ?? _me?.Email ?? "?").Trim() is { Length: > 0 } s ? s[..1].ToUpperInvariant() : "?";

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var response = await Http.GetAsync("/djehuti/api/auth/me");
            if (response.IsSuccessStatusCode)
            {
                _me = await response.Content.ReadFromJsonAsync<MeResponse>();
            }
        }
        catch
        {
        }
        finally
        {
            _loading = false;
        }
    }

    private void ToggleMenu() => _menuOpen = !_menuOpen;

    private async Task SignOut()
    {
        try { await Http.PostAsync("/djehuti/api/auth/logout", null); }
        catch { }
        Nav.NavigateTo("/", forceLoad: true);
    }

    private sealed class MeResponse
    {
        public string? DisplayName { get; set; }
        public string Email { get; set; } = "";
    }
}
