@namespace Djehuti.Teacher.Layout
@implements IDisposable
@inject WebLlmClient WebLlm

<div class="teacher-tutor">
    <div class="teacher-tutor-header">
        <span class="teacher-tutor-avatar">@(WebLlm.State == WebLlmState.Ready ? "🟢" : "💬")</span>
        <span>Tutor</span>
    </div>
    <p class="teacher-tutor-status">@StatusText()</p>

    <div class="teacher-tutor-messages">
        @if (_turns.Count == 0)
        {
            <p class="teacher-muted">Ask a question about "@TopicTitle" — the tutor works through it with you rather than just handing over the answer.</p>
        }
        @foreach (var turn in _turns)
        {
            <div class="teacher-tutor-message teacher-tutor-message-@turn.Role">
                <div class="teacher-tutor-bubble">@turn.Content</div>
            </div>
        }
        @if (_sending)
        {
            <div class="teacher-tutor-message teacher-tutor-message-assistant">
                <div class="teacher-tutor-bubble teacher-tutor-pending">Thinking…</div>
            </div>
        }
    </div>

    <form class="teacher-tutor-input-row" @onsubmit="SendAsync">
        <input class="teacher-settings-input"
               placeholder="@InputPlaceholder()"
               @bind="_input" @bind:event="oninput"
               disabled="@(_sending || WebLlm.State != WebLlmState.Ready)" />
        <button type="submit" class="teacher-cta" disabled="@(_sending || WebLlm.State != WebLlmState.Ready || string.IsNullOrWhiteSpace(_input))">Ask</button>
    </form>
</div>

@code {
    [Parameter, EditorRequired] public string LessonTitle { get; set; } = "";
    [Parameter, EditorRequired] public string TopicTitle { get; set; } = "";
    [Parameter, EditorRequired] public string TopicContent { get; set; } = "";

    private bool _sending;
    private string _input = "";
    private List<(string Role, string Content)> _turns = new();

    protected override void OnInitialized()
    {
        WebLlm.StateChanged += HandleStateChanged;
        _ = WebLlm.EnsureReadyAsync();
    }

    private void HandleStateChanged() => InvokeAsync(StateHasChanged);

    private string StatusText() => WebLlm.State switch
    {
        WebLlmState.Ready => "Free local tutor, running in your browser.",
        WebLlmState.Loading => $"Downloading tutor model ({(int)(WebLlm.ProgressFraction * 100)}%)…",
        WebLlmState.Unsupported => "Your browser doesn't support WebGPU. Add a key in AI Setup for a BYOK tutor (coming soon).",
        WebLlmState.Failed => "Local tutor failed to load. Add a key in AI Setup for a BYOK tutor (coming soon).",
        _ => "",
    };

    private string InputPlaceholder() => WebLlm.State == WebLlmState.Ready
        ? "Ask a question…"
        : "Waiting for the tutor…";

    private async Task SendAsync()
    {
        var text = _input.Trim();
        if (string.IsNullOrEmpty(text) || _sending || WebLlm.State != WebLlmState.Ready) return;

        _input = "";
        var history = _turns.ToList();
        _turns.Add(("user", text));
        _sending = true;
        StateHasChanged();

        try
        {
            var systemPrompt =
                $"You are a patient, encouraging tutor helping a student understand the topic \"{TopicTitle}\" " +
                $"from the lesson \"{LessonTitle}\". Here is the topic's content for reference:\n\n{TopicContent}\n\n" +
                "Your job is to build genuine understanding, not to just hand over final answers. When the student " +
                "asks how to solve something, ask a guiding question or point them at the relevant part of the " +
                "content first, and let them work through it with you. Keep answers short -- a few sentences, not " +
                "an essay.";

            var messages = new List<(string Role, string Content)> { ("system", systemPrompt) };
            messages.AddRange(history);
            messages.Add(("user", text));

            var reply = await WebLlm.ChatAsync(messages);
            _turns.Add(("assistant", reply));
        }
        catch (Exception ex)
        {
            _turns.Add(("assistant", $"Sorry, something went wrong: {ex.Message}"));
        }
        finally
        {
            _sending = false;
        }
    }

    public void Dispose()
    {
        WebLlm.StateChanged -= HandleStateChanged;
    }
}
