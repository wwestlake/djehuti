@namespace Djehuti.Teacher.Components
@inject IJSRuntime JS
@implements IAsyncDisposable
@using Djehuti.Teacher.Services

<div id="@_elementId" class="teacher-music-staff"></div>

@code {
    [Parameter, EditorRequired] public MusicScore Score { get; set; } = new();
    [Parameter] public HashSet<string> HighlightedNoteIds { get; set; } = new();
    [Parameter] public EventCallback<MusicNote> OnNoteClicked { get; set; }

    private readonly string _elementId = $"music-staff-{Guid.NewGuid():N}";
    private IJSObjectReference? _module;
    private DotNetObjectReference<MusicStaff>? _selfRef;
    private string _lastRenderedSignature = "";

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        // Re-render whenever the score or highlight set actually changed --
        // cheap signature check avoids redrawing the whole staff (and losing
        // click listeners momentarily) on every unrelated parent re-render.
        var signature = System.Text.Json.JsonSerializer.Serialize(Score) + "|" + string.Join(",", HighlightedNoteIds.OrderBy(x => x));
        if (signature == _lastRenderedSignature && !firstRender) return;
        _lastRenderedSignature = signature;

        try
        {
            _module ??= await JS.InvokeAsync<IJSObjectReference>("import", "./js/music-interop.js");
            _selfRef ??= DotNetObjectReference.Create(this);
            var scoreJson = System.Text.Json.JsonSerializer.Serialize(Score);
            var highlightedJson = System.Text.Json.JsonSerializer.Serialize(HighlightedNoteIds);
            await _module.InvokeVoidAsync("renderScore", _elementId, scoreJson, highlightedJson, _selfRef);
        }
        catch (JSException)
        {
            _module = null; // stale cached module across a deploy -- retry next render
        }
    }

    [JSInvokable]
    public async Task NotifyNoteClicked(string noteId)
    {
        var note = Score.Measures.SelectMany(m => m.Notes).FirstOrDefault(n => n.Id == noteId);
        if (note is not null && OnNoteClicked.HasDelegate)
        {
            await OnNoteClicked.InvokeAsync(note);
        }
    }

    public async ValueTask DisposeAsync()
    {
        _selfRef?.Dispose();
        if (_module is not null)
        {
            try { await _module.DisposeAsync(); }
            catch (JSDisconnectedException) { }
        }
    }
}
