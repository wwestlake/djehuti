@namespace Djehuti.Teacher.Components

<div class="teacher-diagram-panel">
    <svg viewBox="0 0 560 160" xmlns="http://www.w3.org/2000/svg" style="width:100%; max-width:560px; display:block; margin:0 auto;">
        @foreach (var key in _whiteKeys)
        {
            var highlighted = HighlightedIds.Contains(key.Id);
            <rect x="@key.X" y="0" width="@WhiteKeyWidth" height="150"
                  class="teacher-diagram-note @(highlighted ? "highlighted" : "")"
                  fill="@(highlighted ? "#f5a623" : "#ffffff")" stroke="#333" stroke-width="1"
                  @onclick="() => HandleClick(key)" />
            <g transform="@($"translate({key.X + WhiteKeyWidth / 2},140)")" text-anchor="middle" font-size="15" fill="#333" style="pointer-events:none;"><text>@key.Pitch</text></g>
        }
        @foreach (var key in _blackKeys)
        {
            var highlighted = HighlightedIds.Contains(key.Id);
            <rect x="@key.X" y="0" width="@BlackKeyWidth" height="95"
                  class="teacher-diagram-note @(highlighted ? "highlighted" : "")"
                  fill="@(highlighted ? "#f5a623" : "#222222")" stroke="#000" stroke-width="1"
                  @onclick="() => HandleClick(key)" />
        }
    </svg>
</div>

@code {
    [Parameter] public HashSet<string> HighlightedIds { get; set; } = new();
    [Parameter] public EventCallback<(string Id, string Description)> OnPositionClicked { get; set; }

    private const double WhiteKeyWidth = 40;
    private const double BlackKeyWidth = 24;
    private static readonly string[] WhiteLetters = { "C", "D", "E", "F", "G", "A", "B" };
    // Which white-key index (0-6, within an octave) has a black key immediately after it.
    private static readonly int[] BlackAfterWhiteIndex = { 0, 1, 3, 4, 5 };

    private record Key(string Id, string Pitch, double X);

    private List<Key> _whiteKeys = new();
    private List<Key> _blackKeys = new();

    protected override void OnInitialized()
    {
        // Two octaves, C4 through B5.
        for (var octave = 4; octave <= 5; octave++)
        {
            var octaveOffset = (octave - 4) * 7 * WhiteKeyWidth;
            for (var i = 0; i < WhiteLetters.Length; i++)
            {
                var pitch = $"{WhiteLetters[i]}{octave}";
                _whiteKeys.Add(new Key(pitch, pitch, octaveOffset + i * WhiteKeyWidth));
            }
            foreach (var i in BlackAfterWhiteIndex)
            {
                var letter = WhiteLetters[i];
                var pitch = $"{letter}#{octave}";
                var x = octaveOffset + (i + 1) * WhiteKeyWidth - BlackKeyWidth / 2;
                _blackKeys.Add(new Key(pitch, pitch, x));
            }
        }
    }

    private async Task HandleClick(Key key)
    {
        if (OnPositionClicked.HasDelegate)
        {
            await OnPositionClicked.InvokeAsync((key.Id, $"the note {key.Pitch} on the piano"));
        }
    }

    public static string Legend =>
        "This is a piano keyboard, two octaves from C4 to B5. Each key's id is its pitch name, e.g. \"C4\" or \"F#5\".";
}
