@page "/your-lessons"
@inject TeacherApiClient Api
@inject NavigationManager Nav
@inject HttpClient Http

<PageTitle>Your Lessons — Djehuti Teacher</PageTitle>

<div class="teacher-page">
    <h1>Your Lessons</h1>
    <p class="teacher-page-subtitle">Lesson plans you've created.</p>

    @if (!_signedIn && !_checkingAuth)
    {
        <div class="teacher-empty">
            <p>Sign in to create and manage lesson plans.</p>
            <a class="teacher-cta" href="/">Sign in</a>
        </div>
    }
    else if (_loading || _checkingAuth)
    {
        <p class="teacher-muted">Loading…</p>
    }
    else
    {
        <form class="teacher-inline-form" @onsubmit="CreateAsync">
            <input @bind="_newTitle" placeholder="New lesson plan title" maxlength="120" />
            <button type="submit" class="teacher-cta" disabled="@(_creating || string.IsNullOrWhiteSpace(_newTitle))">
                @(_creating ? "Creating…" : "Create")
            </button>
        </form>

        @if (_plans.Count == 0)
        {
            <p class="teacher-muted">Nothing yet — create your first lesson plan above.</p>
        }
        else
        {
            <div class="teacher-card-grid">
                @foreach (var plan in _plans)
                {
                    <a class="teacher-lesson-card" href="@($"edit/{plan.Id}")">
                        <span class="teacher-lesson-status @(plan.Published ? "published" : "draft")">@(plan.Published ? "Published" : "Draft")</span>
                        <h3>@plan.Title</h3>
                        <span class="teacher-lesson-meta">@plan.Topics.Count topic@(plan.Topics.Count == 1 ? "" : "s")</span>
                    </a>
                }
            </div>
        }
    }
</div>

@code {
    private bool _checkingAuth = true;
    private bool _signedIn;
    private bool _loading = true;
    private bool _creating;
    private string _newTitle = "";
    private List<LessonPlan> _plans = new();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var response = await Http.GetAsync("/djehuti/api/auth/me");
            _signedIn = response.IsSuccessStatusCode;
        }
        catch { _signedIn = false; }
        _checkingAuth = false;

        if (_signedIn)
        {
            _plans = await Api.GetMineAsync();
        }
        _loading = false;
    }

    private async Task CreateAsync()
    {
        if (string.IsNullOrWhiteSpace(_newTitle)) return;
        _creating = true;
        var created = await Api.CreateAsync(_newTitle, null, null);
        _creating = false;
        if (created is not null)
        {
            Nav.NavigateTo($"edit/{created.Id}");
        }
    }
}
