@page "/learning-tracks"
@inject TeacherApiClient Api

<PageTitle>Learning Tracks — Djehuti Teacher</PageTitle>

<div class="teacher-page">
    <h1>Learning Tracks</h1>
    <p class="teacher-page-subtitle">
        Structured learning paths organized by subject. Complete lessons within a track and track your overall progress.
    </p>

    @if (_loading)
    {
        <p class="teacher-muted">Loading…</p>
    }
    else if (_tracks.Count == 0)
    {
        <div class="teacher-empty">
            <p>No learning tracks available yet.</p>
            <a class="teacher-cta" href="catalog">Browse lessons instead →</a>
        </div>
    }
    else
    {
        <div class="teacher-card-grid">
            @foreach (var track in _tracks)
            {
                <a class="teacher-track-card" href="@($"learning-track/{track.Slug}")">
                    <div class="teacher-track-difficulty">@track.Difficulty</div>
                    <h3>@track.Title</h3>
                    @if (!string.IsNullOrWhiteSpace(track.Description))
                    {
                        <p>@track.Description</p>
                    }
                    <div class="teacher-track-meta">
                        @if (track.EstimatedHours.HasValue)
                        {
                            <span class="teacher-track-hours">⏱ @track.EstimatedHours hours</span>
                        }
                    </div>
                </a>
            }
        </div>
    }
</div>

@code {
    private bool _loading = true;
    private List<LearningTrack> _tracks = new();

    [Serializable]
    public class LearningTrack
    {
        public Guid Id { get; set; }
        public string Title { get; set; } = "";
        public string Slug { get; set; } = "";
        public string? Description { get; set; }
        public string Difficulty { get; set; } = "beginner";
        public int? EstimatedHours { get; set; }
        public int Position { get; set; }
        public bool Published { get; set; }
        public DateTimeOffset CreatedAt { get; set; }
        public DateTimeOffset UpdatedAt { get; set; }
    }

    protected override async Task OnInitializedAsync()
    {
        _tracks = await Api.GetLearningTracksAsync();
        _loading = false;
    }
}
