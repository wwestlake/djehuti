@page "/lesson/{Slug}"
@inject TeacherApiClient Api
@inject IJSRuntime JS
@using Djehuti.Teacher.Components
@using Djehuti.Teacher.Services

<PageTitle>@(_plan?.Title ?? "Lesson") — Djehuti Teacher</PageTitle>

<div class="teacher-page teacher-page-wide">
    @if (_loading)
    {
        <p class="teacher-muted">Loading…</p>
    }
    else if (_plan is null)
    {
        <div class="teacher-empty">
            <p>That lesson doesn't exist, or isn't published yet.</p>
            <a class="teacher-cta" href="catalog">Back to catalog →</a>
        </div>
    }
    else
    {
        @if (!string.IsNullOrWhiteSpace(_plan.Subject))
        {
            <span class="teacher-lesson-subject">@_plan.Subject</span>
        }
        <h1>@_plan.Title</h1>
        @if (!string.IsNullOrWhiteSpace(_plan.Description))
        {
            <p class="teacher-page-subtitle">@_plan.Description</p>
        }

        @if (_plan.Topics.Count == 0)
        {
            <p class="teacher-muted">This lesson doesn't have any topics yet.</p>
        }
        else
        {
            <div class="teacher-classroom-layout">
                <nav class="teacher-topic-nav">
                    @for (var i = 0; i < _plan.Topics.Count; i++)
                    {
                        var index = i;
                        <button type="button"
                                class="teacher-topic-nav-item @(index == _activeTopic ? "active" : "")"
                                @onclick="() => _activeTopic = index">
                            @(index + 1). @_plan.Topics[index].Title
                        </button>
                    }
                </nav>

                @{ var topic = _plan.Topics[_activeTopic]; }

                <div class="teacher-board">
                    <div class="teacher-board-surface">
                        <h2>@topic.Title</h2>
                        @if (topic.Kind == "notation")
                        {
                            EnsureScoreLoaded(topic);
                            @if (!string.IsNullOrWhiteSpace(topic.ContentMarkdown))
                            {
                                <div class="teacher-markdown teacher-board-content">@((MarkupString)RenderMarkdown(topic.ContentMarkdown))</div>
                            }
                            <MusicStaff Score="_currentScore" HighlightedNoteIds="_highlightedNoteIds" OnNoteClicked="HandleNoteClicked" />
                        }
                        else if (topic.Kind == "fretboard")
                        {
                            ResetHighlightsIfNewTopic();
                            @if (!string.IsNullOrWhiteSpace(topic.ContentMarkdown))
                            {
                                <div class="teacher-markdown teacher-board-content">@((MarkupString)RenderMarkdown(topic.ContentMarkdown))</div>
                            }
                            <FretboardDiagram HighlightedIds="_highlightedNoteIds" OnPositionClicked="HandleDiagramClicked" />
                        }
                        else if (topic.Kind == "piano")
                        {
                            ResetHighlightsIfNewTopic();
                            @if (!string.IsNullOrWhiteSpace(topic.ContentMarkdown))
                            {
                                <div class="teacher-markdown teacher-board-content">@((MarkupString)RenderMarkdown(topic.ContentMarkdown))</div>
                            }
                            <PianoKeys HighlightedIds="_highlightedNoteIds" OnPositionClicked="HandleDiagramClicked" />
                        }
                        else if (topic.Kind == "circleoffifths")
                        {
                            ResetHighlightsIfNewTopic();
                            @if (!string.IsNullOrWhiteSpace(topic.ContentMarkdown))
                            {
                                <div class="teacher-markdown teacher-board-content">@((MarkupString)RenderMarkdown(topic.ContentMarkdown))</div>
                            }
                            <CircleOfFifths HighlightedIds="_highlightedNoteIds" OnPositionClicked="HandleDiagramClicked" />
                        }
                        else
                        {
                            @if (!string.IsNullOrWhiteSpace(topic.VideoUrl))
                            {
                                <div class="teacher-video-embed">
                                    <iframe src="@topic.VideoUrl" allowfullscreen title="@topic.Title"></iframe>
                                </div>
                            }
                            <div class="teacher-markdown teacher-board-content" @ref="_boardContentRef">
                                @((MarkupString)RenderMarkdown(topic.ContentMarkdown))
                            </div>
                        }
                    </div>

                    <div class="teacher-topic-pager">
                        <button type="button" class="teacher-cta teacher-cta-ghost" disabled="@(_activeTopic == 0)" @onclick="() => _activeTopic--">← Previous</button>
                        <button type="button" class="teacher-cta" disabled="@(_activeTopic == _plan.Topics.Count - 1)" @onclick="() => _activeTopic++">Next →</button>
                    </div>
                </div>

                <div class="teacher-classroom-chat">
                    <TutorChat @ref="_tutorChat" @key="_activeTopic" LessonTitle="@_plan.Title" TopicTitle="@topic.Title" TopicContent="@topic.ContentMarkdown"
                               Score="@(topic.Kind == "notation" ? _currentScore : null)"
                               HighlightedNoteIds="_highlightedNoteIds"
                               OnHighlightRequested="HandleHighlightRequested"
                               OnScoreReplaceRequested="HandleScoreReplaceRequested"
                               DiagramLegend="@DiagramLegendFor(topic.Kind)" />
                </div>
            </div>
        }
    }
</div>

@code {
    [Parameter] public string Slug { get; set; } = "";

    private bool _loading = true;
    private LessonPlan? _plan;
    private int _activeTopic;
    private ElementReference _boardContentRef;
    private IJSObjectReference? _module;
    private TutorChat? _tutorChat;
    private MusicScore _currentScore = new();
    private HashSet<string> _highlightedNoteIds = new();
    private int _scoreLoadedForTopic = -1;

    // The AI (and note clicks) can mutate _currentScore/_highlightedNoteIds
    // for the current viewing session -- that's the "AI can point at and
    // change what's on screen" behavior from the spec. It is never written
    // back through TeacherApiClient: a tutoring session illustrating a scale
    // must not silently overwrite the shared lesson content every student
    // sees, only what this student is currently looking at.
    private void EnsureScoreLoaded(LessonTopic topic)
    {
        if (_scoreLoadedForTopic == _activeTopic) return;
        _scoreLoadedForTopic = _activeTopic;
        _highlightedNoteIds = new();
        try
        {
            _currentScore = string.IsNullOrWhiteSpace(topic.NotationJson)
                ? new MusicScore()
                : System.Text.Json.JsonSerializer.Deserialize<MusicScore>(topic.NotationJson, new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true }) ?? new MusicScore();
        }
        catch
        {
            _currentScore = new MusicScore();
        }
    }

    private async Task HandleNoteClicked(MusicNote note)
    {
        if (_tutorChat is not null)
        {
            await _tutorChat.InjectNoteClickAsync(note);
        }
    }

    private async Task HandleDiagramClicked((string Id, string Description) position)
    {
        if (_tutorChat is not null)
        {
            await _tutorChat.InjectDiagramClickAsync(position.Description);
        }
    }

    private void HandleHighlightRequested(HashSet<string> noteIds)
    {
        _highlightedNoteIds = noteIds;
        StateHasChanged();
    }

    private void HandleScoreReplaceRequested(MusicScore score)
    {
        _currentScore = score;
        StateHasChanged();
    }

    // Fretboard/piano/circle-of-fifths topics have no authored per-topic
    // content to load (unlike a notation topic's score), only a highlight
    // set that should reset when the student switches to a different topic.
    private void ResetHighlightsIfNewTopic()
    {
        if (_scoreLoadedForTopic == _activeTopic) return;
        _scoreLoadedForTopic = _activeTopic;
        _highlightedNoteIds = new();
    }

    private static string? DiagramLegendFor(string kind) => kind switch
    {
        "fretboard" => Components.FretboardDiagram.Legend,
        "piano" => Components.PianoKeys.Legend,
        "circleoffifths" => Components.CircleOfFifths.Legend,
        _ => null,
    };

    protected override async Task OnInitializedAsync()
    {
        _plan = await Api.GetBySlugAsync(Slug);
        _loading = false;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_plan is not null && _plan.Topics.Count > 0)
        {
            await TryInvokeJsAsync("renderMath", _boardContentRef);
        }
    }

    private static string RenderMarkdown(string markdown) =>
        string.IsNullOrWhiteSpace(markdown) ? "" : Markdig.Markdown.ToHtml(markdown);

    // Same failure-tolerant pattern as DjeLab's ChatPane -- math rendering
    // is cosmetic, so a stale cached module or missing CDN script must never
    // take down the lesson page itself.
    private async Task TryInvokeJsAsync(string function, params object[] args)
    {
        try
        {
            _module ??= await JS.InvokeAsync<IJSObjectReference>("import", "./js/teacher-interop.js");
            await _module.InvokeVoidAsync(function, args);
        }
        catch (JSException)
        {
            _module = null;
        }
    }
}
