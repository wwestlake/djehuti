@page "/ai-setup"
@inject AiConfigStore ConfigStore
@using Djehuti.Teacher.Services

<PageTitle>AI Setup — Djehuti Teacher</PageTitle>

<div class="teacher-page">
    <h1>AI Setup</h1>
    <p class="teacher-page-subtitle">
        Add your own AI provider key to unlock live tutoring — a per-student AI that works through problems
        with you rather than just giving the answer. Lesson content itself is free to read without a key;
        the key powers the interactive tutoring layer on top of it.
    </p>

    <div class="teacher-settings-card">
        @if (_loading)
        {
            <p class="teacher-muted">Loading…</p>
        }
        else
        {
            <label class="teacher-settings-label" for="provider">AI Provider</label>
            <select id="provider" class="teacher-settings-input" @bind="_provider">
                <option value="openai">OpenAI (gpt-4o-mini, gpt-4o)</option>
                <option value="anthropic">Anthropic Claude (claude-opus-4-1, claude-sonnet-4-5)</option>
                <option value="google_gemini">Google Gemini (gemini-2.0-flash, gemini-1.5-pro)</option>
                <option value="mistral">Mistral (mistral-large, mistral-small)</option>
            </select>

            <label class="teacher-settings-label" for="api-key">API Key</label>
            <div class="teacher-settings-key-row">
                <input id="api-key"
                       class="teacher-settings-input"
                       type="@(_showKey ? "text" : "password")"
                       autocomplete="off"
                       placeholder="Your API key"
                       @bind="_apiKey"
                       @bind:event="oninput" />
                <button type="button" class="teacher-settings-toggle" @onclick="() => _showKey = !_showKey">
                    @(_showKey ? "Hide" : "Show")
                </button>
            </div>

            <label class="teacher-settings-label" for="model">Model</label>
            <input id="model"
                   class="teacher-settings-input"
                   type="text"
                   placeholder="@AiConfigStore.DefaultModel"
                   @bind="_model"
                   @bind:event="oninput" />

            <div class="teacher-settings-actions">
                <button type="button" class="teacher-cta" @onclick="Save" disabled="@_saving">
                    @(_saving ? "Saving…" : "Save")
                </button>
                <button type="button" class="teacher-cta teacher-cta-ghost" @onclick="Clear" disabled="@_saving">
                    Remove key
                </button>
                @if (_savedMessage is not null)
                {
                    <span class="teacher-settings-saved">@_savedMessage</span>
                }
            </div>

            <p class="teacher-settings-hint">
                Your key is stored only in this browser's local storage and sent directly from your browser to
                the AI provider. It never touches Djehuti's servers. Without a key, you can still read every
                lesson's content; the key powers the interactive tutoring layer that works through problems with you.
            </p>
        }
    </div>
</div>

@code {
    private bool _loading = true;
    private bool _saving;
    private bool _showKey;
    private string _apiKey = "";
    private string _model = "";
    private string _provider = "openai";
    private string? _savedMessage;

    protected override async Task OnInitializedAsync()
    {
        _apiKey = await ConfigStore.GetApiKeyAsync() ?? "";
        _model = await ConfigStore.GetModelAsync();
        var provider = await ConfigStore.GetProviderAsync();
        _provider = provider switch
        {
            ApiProvider.OpenAi => "openai",
            ApiProvider.Anthropic => "anthropic",
            ApiProvider.GoogleGemini => "google_gemini",
            ApiProvider.Mistral => "mistral",
            _ => "openai",
        };
        _loading = false;
    }

    private ApiProvider ParseProvider(string value) => value switch
    {
        "openai" => ApiProvider.OpenAi,
        "anthropic" => ApiProvider.Anthropic,
        "google_gemini" => ApiProvider.GoogleGemini,
        "mistral" => ApiProvider.Mistral,
        _ => ApiProvider.OpenAi,
    };

    private async Task Save()
    {
        _saving = true;
        _savedMessage = null;
        await ConfigStore.SetApiKeyAsync(_apiKey);
        await ConfigStore.SetModelAsync(_model);
        await ConfigStore.SetProviderAsync(ParseProvider(_provider));
        _saving = false;
        _savedMessage = "Saved.";
    }

    private async Task Clear()
    {
        _saving = true;
        _savedMessage = null;
        await ConfigStore.ClearAsync();
        _apiKey = "";
        _model = "";
        _provider = "openai";
        _saving = false;
        _savedMessage = "Removed.";
    }
}
