@page "/"
@inject HttpClient Http

<PageTitle>DjeLab — Djehuti Lab AI+</PageTitle>

<div class="djelab-hero">
    <img src="images/djelab-logo-nav.png" alt="DjeLab" class="djelab-hero-logo" />
    <h1>DjeLab</h1>
    <p class="djelab-tagline">Djehuti Lab AI+ — a browser workspace with a built-in local host / WebLLM mode for tours and basic help, plus BYOK mode when you want more power.</p>

    <div class="djelab-status-card">
        @if (_loading)
        {
            <p>Checking connection to Djehuti.Api…</p>
        }
        else if (_error is not null)
        {
            <p class="djelab-status-error">Could not reach the API: @_error</p>
        }
        else if (_me is not null)
        {
            <p class="djelab-status-ok">Connected. Signed in as <strong>@_me.DisplayName</strong>.</p>
        }
        else
        {
            <p class="djelab-status-ok">Connected to Djehuti.Api. DjeLab can still run in local host mode without a key.</p>
        }
    </div>
</div>

@code {
    private bool _loading = true;
    private string? _error;
    private MeResponse? _me;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var response = await Http.GetAsync("/djehuti/api/auth/me");
            if (response.IsSuccessStatusCode)
            {
                _me = await response.Content.ReadFromJsonAsync<MeResponse>();
            }
            else if (response.StatusCode != System.Net.HttpStatusCode.Unauthorized)
            {
                _error = $"HTTP {(int)response.StatusCode}";
            }
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _loading = false;
        }
    }

    private sealed class MeResponse
    {
        public string? DisplayName { get; set; }
        public string? Email { get; set; }
    }
}
