@page "/"
@inject HttpClient Http

<PageTitle>DjeLab — Djehuti Lab AI+</PageTitle>

<div class="djelab-hero">
    <img src="images/djelab-logo-nav.png" alt="DjeLab" class="djelab-hero-logo" />
    <h1>DjeLab</h1>
    <p class="djelab-tagline">Djehuti Lab AI+ is open to everyone at the door. You can try the workspace anonymously, use Ibis for tours and basic help, and add your own key later if you want the stronger Seshat assistant.</p>

    <div class="djelab-status-card">
        @if (_loading)
        {
            <p>Checking connection to Djehuti.Api…</p>
        }
        else if (_error is not null)
        {
            <p class="djelab-status-error">Could not reach the API: @_error</p>
        }
        else if (_me is not null)
        {
            <p class="djelab-status-ok">Connected. Signed in as <strong>@_me.DisplayName</strong>. Your saved layout and file work can follow you across devices.</p>
        }
        else
        {
            <p class="djelab-status-ok">Connected to Djehuti.Api. You can explore DjeLab without signing in; sign in later to save your layout and file workspace.</p>
        }
    </div>

    <div class="djelab-hero-grid">
        <div class="djelab-hero-card">
            <h2>Public by default</h2>
            <p>Anyone can open the home page and try the app without a login. Sign-in is only for saving and syncing.</p>
        </div>
        <div class="djelab-hero-card">
            <h2>Ibis for guidance</h2>
            <p>Ibis is the friendly host and tour guide. It helps new visitors learn the workspace without needing a key.</p>
        </div>
        <div class="djelab-hero-card">
            <h2>Seshat for heavier work</h2>
            <p>Add your own OpenAI key when you want a BYOK assistant that can tackle more demanding analysis and coding.</p>
        </div>
    </div>
</div>

@code {
    private bool _loading = true;
    private string? _error;
    private MeResponse? _me;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var response = await Http.GetAsync("/djehuti/api/auth/me");
            if (response.IsSuccessStatusCode)
            {
                _me = await response.Content.ReadFromJsonAsync<MeResponse>();
            }
            else if (response.StatusCode != System.Net.HttpStatusCode.Unauthorized)
            {
                _error = $"HTTP {(int)response.StatusCode}";
            }
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _loading = false;
        }
    }

    private sealed class MeResponse
    {
        public string? DisplayName { get; set; }
        public string? Email { get; set; }
    }
}
