@using Djehuti.DjeLab.Services
@implements IAsyncDisposable
@inject IJSRuntime JS

<div class="render-music">
    @if (!string.IsNullOrWhiteSpace(Descriptor?.Title))
    {
        <h4>@Descriptor.Title</h4>
    }
    <div class="render-music-staff" id="@_elementId"></div>
    @if (string.IsNullOrWhiteSpace(Descriptor?.Abc))
    {
        <div class="render-music-placeholder">
            [No ABC notation provided]
        </div>
    }
</div>

@code {
    [Parameter] public MusicDescriptor? Descriptor { get; set; }

    private string _elementId = "";
    private IJSObjectReference? _module;

    protected override void OnInitialized()
    {
        _elementId = $"music-{Descriptor?.Id ?? Guid.NewGuid().ToString("N")[..8]}";
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || Descriptor is null || string.IsNullOrWhiteSpace(Descriptor.Abc))
            return;

        try
        {
            _module ??= await JS.InvokeAsync<IJSObjectReference>("import", "./js/abc-renderer.js");
            if (_module != null)
            {
                await _module.InvokeVoidAsync("renderAbc", _elementId, Descriptor.Abc);
            }
        }
        catch
        {
            // If abc.js isn't available or fails, just display the ABC text
        }
    }

    public async ValueTask DisposeAsync()
    {
        if (_module is not null)
        {
            try { await _module.DisposeAsync(); }
            catch { /* cleanup on dispose; failure is not critical */ }
        }
    }
}
