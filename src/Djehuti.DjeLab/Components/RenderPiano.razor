@using Djehuti.DjeLab.Services
@using System.Text.Json
@implements IAsyncDisposable
@inject IJSRuntime JS

<div class="render-piano">
    @if (!string.IsNullOrWhiteSpace(Descriptor?.Title))
    {
        <h4>@Descriptor.Title</h4>
    }
    <div class="render-piano-keyboard" id="@_elementId"></div>
</div>

@code {
    [Parameter] public PianoDescriptor? Descriptor { get; set; }

    private string _elementId = "";
    private IJSObjectReference? _module;

    protected override void OnInitialized()
    {
        _elementId = $"piano-{Descriptor?.Id ?? Guid.NewGuid().ToString("N")[..8]}";
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || Descriptor is null) return;

        _module ??= await JS.InvokeAsync<IJSObjectReference>("import", "./js/piano-renderer.js");
        if (_module == null) return;

        var highlightedJson = Descriptor.Highlighted != null && Descriptor.Highlighted.Count > 0
            ? JsonSerializer.Serialize(Descriptor.Highlighted)
            : "[]";

        await _module.InvokeVoidAsync("renderPiano", _elementId, Descriptor.StartOctave, Descriptor.EndOctave, highlightedJson);
    }

    public async ValueTask DisposeAsync()
    {
        if (_module is not null)
        {
            try { await _module.DisposeAsync(); }
            catch { /* cleanup on dispose; failure is not critical */ }
        }
    }
}
