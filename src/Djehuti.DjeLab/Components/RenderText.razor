@using Djehuti.DjeLab.Services

<div class="render-text">
    <div class="render-text-content" style="@GetTextStyle()">
        @Descriptor?.Content
    </div>
</div>

@code {
    [Parameter] public TextDescriptor? Descriptor { get; set; }

    private string GetTextStyle()
    {
        if (Descriptor is null)
            return "";

        var styles = new List<string>();

        var sizeClass = Descriptor.Size?.ToLowerInvariant() ?? "medium";
        var fontSize = sizeClass switch
        {
            "small" => "0.875rem",
            "large" => "1.25rem",
            "xlarge" => "1.5rem",
            _ => "1rem"
        };
        styles.Add($"font-size: {fontSize};");

        var align = Descriptor.Align?.ToLowerInvariant() ?? "left";
        styles.Add($"text-align: {(align is "center" or "right" ? align : "left")};");

        return string.Join(" ", styles);
    }
}
