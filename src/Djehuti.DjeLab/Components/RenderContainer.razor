@using Djehuti.DjeLab.Services

<div class="render-container" style="@GetContainerStyle()">
    @if (Descriptor?.Children is { Count: > 0 })
    {
        @foreach (var childId in Descriptor.Children)
        {
            @if (AllDescriptors?.FirstOrDefault(d => d.Id == childId) is { } child)
            {
                <div class="render-container-child">
                    @switch (child.Type)
                    {
                        case "text":
                            @if (child is TextDescriptor)
                            {
                                <RenderText Descriptor="(TextDescriptor)child" />
                            }
                            break;
                        case "graph":
                            @if (child is GraphDescriptor)
                            {
                                <RenderGraph Descriptor="(GraphDescriptor)child" />
                            }
                            break;
                        // Other cases can be added as needed
                    }
                </div>
            }
        }
    }
</div>

@code {
    [Parameter] public ContainerDescriptor? Descriptor { get; set; }
    [Parameter] public IReadOnlyList<RenderDescriptor>? AllDescriptors { get; set; }

    private string GetContainerStyle()
    {
        if (Descriptor is null)
            return "";

        var layout = Descriptor.Layout?.ToLowerInvariant() ?? "column";
        var display = layout switch
        {
            "row" => "display: flex; flex-direction: row; gap: 1rem;",
            "grid" => "display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 1rem;",
            _ => "display: flex; flex-direction: column; gap: 1rem;"
        };

        return display;
    }
}
