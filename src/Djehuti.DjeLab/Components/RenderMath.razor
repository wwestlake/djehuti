@using Djehuti.DjeLab.Services
@inject IJSRuntime JS

<div class="render-math">
    @if (!string.IsNullOrWhiteSpace(Descriptor?.LaTeX))
    {
        <div class="render-math-content" @ref="_mathElement">
            @((MarkupString)(Descriptor.Display
                ? $"$$\\displaystyle {Descriptor.LaTeX}$$"
                : $"$\\textstyle {Descriptor.LaTeX}$"))
        </div>
    }
</div>

@code {
    [Parameter] public MathDescriptor? Descriptor { get; set; }

    private ElementReference _mathElement;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || Descriptor is null || string.IsNullOrWhiteSpace(Descriptor.LaTeX))
            return;

        try
        {
            await JS.InvokeVoidAsync("renderMath", _mathElement);
        }
        catch
        {
            // Math rendering is cosmetic; failure doesn't break functionality
        }
    }
}
