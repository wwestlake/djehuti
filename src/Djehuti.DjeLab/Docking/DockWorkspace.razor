@using System.Text.Json
@using Djehuti.DjeLab.Services
@using Djehuti.DjeLab.Components
@implements IAsyncDisposable
@inject IJSRuntime JS
@inject DjeLabFilesClient FilesClient
@inject WorkspaceActions Actions
@inject DemoMode DemoMode

<div class="dock-workspace" @ref="_containerRef"
     @onpointermove="OnContainerPointerMove" @onpointerup="OnContainerPointerUp" @onpointerleave="OnContainerPointerUp">
    <div class="dock-toolbar">
        <span class="dock-toolbar-title">Workspace <span class="dock-toolbar-hint">— prototype, drag tabs and dividers, not yet saved</span></span>
        <div class="dock-toolbar-actions">
            @if (_closedPanes.Count > 0)
            {
                <select class="dock-reopen-select" @onchange="OnReopenSelected">
                    <option value="">Reopen…</option>
                    @for (var i = 0; i < _closedPanes.Count; i++)
                    {
                        var index = i;
                        <option value="@index">@_closedPanes[index].Title</option>
                    }
                </select>
            }
            <button type="button" class="dock-reset-btn" @onclick="ResetLayout">Reset layout</button>
        </div>
    </div>
    <div class="dock-canvas">
        <DockNodeView Node="_root" Panes="_panes"
                      DraggingPaneId="@_draggingPaneId"
                      HighlightedPaneId="@_highlightedPaneId"
                      TourTitle="@_tourTitle"
                      TourBody="@_tourBody"
                      TourStepLabel="@TourStepLabel"
                      TourIsLastStep="@TourIsLastStep"
                      OnTourNext="AdvanceTour"
                      OnTourEnd="EndTour"
                      OnBeginResize="BeginResize"
                      OnTabDragStart="BeginDragPane"
                      OnTabActivate="ActivatePane"
                      OnDropOnTabStrip="HandleDropOnTabStrip"
                      OnDropOnBody="HandleDropOnBody"
                      OnDragEnd="EndDragPane"
                      OnClosePane="HandleClosePane" />
    </div>
</div>

<DemoAnnotation />
<DemoController />

@code {
    private ElementReference _containerRef;
    private IJSObjectReference? _module;

    private DockNode _root = default!;
    private Dictionary<string, PaneDescriptor> _panes = default!;
    private string? _draggingPaneId;
    private string? _highlightedPaneId;
    private List<string>? _tourSteps;
    private int _tourStepIndex;
    private string? _tourTitle;
    private string? _tourBody;

    private string? TourStepLabel => _tourSteps is { Count: > 1 } ? $"Step {_tourStepIndex + 1} of {_tourSteps.Count}" : null;
    private bool TourIsLastStep => _tourSteps is null || _tourStepIndex >= _tourSteps.Count - 1;
    private bool _layoutLoaded;
    private const string LayoutFilePath = "/djelab-workspace-layout.json";

    private SplitNode? _resizingSplit;
    private int _resizingIndex;
    private double _resizeContainerSizePx;
    private double _resizeStartClientPos;
    private double[] _resizeStartSizes = Array.Empty<double>();
    private BoundingRect? _containerRect;

    // Closing loses whatever live state a pane had (a GraphPane's worker and
    // chart are genuinely gone -- Blazor disposes the component the instant
    // it's removed from the tree) -- this is only enough to recreate an
    // EMPTY pane of the same kind/title, a "bring back what I closed" list,
    // not an undo. Capped so it can't grow unbounded over a long session.
    private const int MaxClosedPanes = 10;
    private readonly List<ClosedPane> _closedPanes = new();
    private sealed record ClosedPane(string Title, string Kind, string AccentColor, string ChatPersona);

    protected override void OnInitialized()
    {
        (_root, _panes) = DemoLayout.CreateDefault();
        Actions.OpenGraphRequested += HandleOpenGraphRequested;
        Actions.WorkspaceTourRequested += HandleWorkspaceTourRequested;
        Actions.WorkspaceTourSequenceRequested += HandleWorkspaceTourSequenceRequested;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await RefreshContainerRectAsync();
            await LoadLayoutAsync();
        }
    }

    private void ResetLayout()
    {
        (_root, _panes) = DemoLayout.CreateDefault();
        _resizingSplit = null;
        _draggingPaneId = null;
        _highlightedPaneId = null;
        _tourSteps = null;
        _tourStepIndex = 0;
        _tourTitle = null;
        _tourBody = null;
        _closedPanes.Clear();
        _ = SaveLayoutAsync(clearIfDefault: true);
    }

    // Graph panes are populated by the AI's run_simulation tool call -- there
    // is no manual "New Graph" / hand-type-code path anymore. Reuses
    // whichever graph pane already exists (the static one from the default
    // layout counts) rather than spawning a fresh tab on every single run:
    // mutating an EXISTING PaneDescriptor's Pending* fields and letting
    // Blazor re-render the already-mounted <GraphPane> with new parameter
    // values triggers a genuine re-run there (see GraphPane's
    // OnParametersSetAsync), without destroying and recreating the
    // component. Only creates a new pane if none exists -- e.g. the first
    // run ever, or after the user closed the last graph pane.
    private void HandleOpenGraphRequested(OpenGraphRequest request)
    {
        var existing = _panes.Values.FirstOrDefault(p => p.Kind == "graph");
        if (existing is not null)
        {
            existing.PendingRunId = request.RunId;
            existing.PendingChartType = request.ChartType;
            existing.PendingXLabel = request.XLabel;
            existing.PendingYLabel = request.YLabel;
            existing.PendingZLabel = request.ZLabel;
            existing.PendingSource = request.SpinozaSource;
            existing.PendingRuntimeInputJson = request.RuntimeInputJson;
            _ = SaveLayoutAsync();
            InvokeAsync(StateHasChanged);
            return;
        }

        var pane = new PaneDescriptor
        {
            Title = "Graph",
            Kind = "graph",
            AccentColor = "#3fa9f5",
            PendingRunId = request.RunId,
            PendingChartType = request.ChartType,
            PendingXLabel = request.XLabel,
            PendingYLabel = request.YLabel,
            PendingZLabel = request.ZLabel,
            PendingSource = request.SpinozaSource,
            PendingRuntimeInputJson = request.RuntimeInputJson
        };
        InsertPane(pane);
        _ = SaveLayoutAsync();
        InvokeAsync(StateHasChanged);
    }

    // Lands a new pane as a tab alongside any existing pane of the same
    // kind (so e.g. several graphs cluster together by default); falls back
    // to the first group in the tree if none of that kind exist yet. The
    // user's normal drag-to-dock gesture (already supported) splits it into
    // its own side-by-side window afterward if they want that instead.
    private void InsertPane(PaneDescriptor pane)
    {
        _panes[pane.Id] = pane;

        var existingSameKindId = _panes.Values.FirstOrDefault(p => p.Kind == pane.Kind && p.Id != pane.Id)?.Id;
        var targetGroup = existingSameKindId is not null
            ? DockTree.FindGroupContainingPane(_root, existingSameKindId)
            : FindFirstGroup(_root);

        if (targetGroup is not null) DockTree.InsertAsTab(_root, targetGroup.Id, pane.Id);
    }

    private static TabGroupNode? FindFirstGroup(DockNode node) => node switch
    {
        TabGroupNode group => group,
        SplitNode split => split.Children.Select(FindFirstGroup).FirstOrDefault(g => g is not null),
        _ => null
    };

    private void HandleClosePane(string paneId)
    {
        if (!_panes.TryGetValue(paneId, out var pane)) return;

        if (string.Equals(_highlightedPaneId, paneId, StringComparison.Ordinal))
            _highlightedPaneId = null;

        _closedPanes.Insert(0, new ClosedPane(pane.Title, pane.Kind, pane.AccentColor, pane.ChatPersona));
        if (_closedPanes.Count > MaxClosedPanes) _closedPanes.RemoveAt(_closedPanes.Count - 1);

        _root = DockTree.RemovePane(_root, paneId);
        _panes.Remove(paneId);
        _ = SaveLayoutAsync();
    }

    private void OnReopenSelected(ChangeEventArgs e)
    {
        if (!int.TryParse(e.Value?.ToString(), out var index) || index < 0 || index >= _closedPanes.Count) return;

        var closed = _closedPanes[index];
        _closedPanes.RemoveAt(index);

        InsertPane(new PaneDescriptor
        {
            Title = closed.Title,
            Kind = closed.Kind,
            AccentColor = closed.AccentColor,
            ChatPersona = closed.ChatPersona
        });
        _ = SaveLayoutAsync();
    }

    // Resize-start must be instantaneous -- a container rect fetched via JS
    // interop at drag-start races against the drag itself (pointermove can
    // fire before the interop call resolves, silently swallowing the first
    // gesture). Instead we keep a cached rect and refresh it in the
    // background after each drag starts, so the *next* drag has a fresh
    // value without ever blocking the current one.
    private void BeginResize(ResizeStart start)
    {
        if (_containerRect == null) return;

        _resizingSplit = start.Split;
        _resizingIndex = start.Index;
        _resizeContainerSizePx = start.Split.Direction == SplitDirection.Row ? _containerRect.Width : _containerRect.Height;
        _resizeStartClientPos = start.Split.Direction == SplitDirection.Row ? start.ClientX : start.ClientY;
        _resizeStartSizes = new[] { start.Split.Sizes[start.Index], start.Split.Sizes[start.Index + 1] };

        _ = RefreshContainerRectAsync();
    }

    private async Task RefreshContainerRectAsync()
    {
        _module ??= await JS.InvokeAsync<IJSObjectReference>("import", "./js/dock-interop.js");
        _containerRect = await _module.InvokeAsync<BoundingRect>("getRect", _containerRef);
    }

    private void OnContainerPointerMove(PointerEventArgs e)
    {
        if (_resizingSplit == null || _resizeContainerSizePx <= 0) return;

        var clientPos = _resizingSplit.Direction == SplitDirection.Row ? e.ClientX : e.ClientY;
        var deltaFrac = (clientPos - _resizeStartClientPos) / _resizeContainerSizePx;

        var newA = _resizeStartSizes[0] + deltaFrac;
        var newB = _resizeStartSizes[1] - deltaFrac;
        const double min = 0.08;
        if (newA < min) { newB -= (min - newA); newA = min; }
        if (newB < min) { newA -= (min - newB); newB = min; }
        if (newA < min || newB < min) return;

        _resizingSplit.Sizes[_resizingIndex] = newA;
        _resizingSplit.Sizes[_resizingIndex + 1] = newB;
        StateHasChanged();
    }

    private void OnContainerPointerUp(PointerEventArgs e)
    {
        _resizingSplit = null;
        _ = SaveLayoutAsync();
    }

    private void BeginDragPane(string paneId) => _draggingPaneId = paneId;
    private void EndDragPane() => _draggingPaneId = null;

    private void ActivatePane(TabActivate activate)
    {
        activate.Group.ActiveIndex = activate.Group.PaneIds.IndexOf(activate.PaneId);
        _ = SaveLayoutAsync();
    }

    private void HandleDropOnTabStrip(TabStripDrop drop)
    {
        if (_draggingPaneId == null) return;
        _root = DockTree.MoveToTabStrip(_root, drop.TargetGroupId, _draggingPaneId, drop.InsertIndex);
        _draggingPaneId = null;
        _ = SaveLayoutAsync();
    }

    private void HandleDropOnBody(BodyDrop drop)
    {
        if (_draggingPaneId == null) return;
        _root = DockTree.MoveToZone(_root, drop.TargetGroupId, _draggingPaneId, drop.Zone);
        _draggingPaneId = null;
        _ = SaveLayoutAsync();
    }

    public async ValueTask DisposeAsync()
    {
        Actions.OpenGraphRequested -= HandleOpenGraphRequested;
        Actions.WorkspaceTourRequested -= HandleWorkspaceTourRequested;
        Actions.WorkspaceTourSequenceRequested -= HandleWorkspaceTourSequenceRequested;
        await SaveLayoutAsync();
        if (_module != null) await _module.DisposeAsync();
    }

    private async Task LoadLayoutAsync()
    {
        try
        {
            var result = await FilesClient.ReadTextPreviewAsync(LayoutFilePath, maxBytes: 256 * 1024);
            if (!result.Success || result.Value is null || string.IsNullOrWhiteSpace(result.Value.Content))
            {
                _layoutLoaded = true;
                return;
            }

            var snapshot = JsonSerializer.Deserialize<DockLayoutSnapshot>(result.Value.Content);
            if (snapshot?.Root is not null && snapshot.Panes.Count > 0 && HasRenderableLayout(snapshot.Root, snapshot.Panes))
            {
                _root = snapshot.Root;
                _panes = snapshot.Panes;
                EnsureAssistantChatPanes();
                RenameLegacyFlowPanes();
            }
            else
            {
                (_root, _panes) = DemoLayout.CreateDefault();
            }
        }
        catch
        {
            // A bad cached layout should never break the app.
            (_root, _panes) = DemoLayout.CreateDefault();
        }
        finally
        {
            _layoutLoaded = true;
            StateHasChanged();
        }
    }

    private async Task SaveLayoutAsync(bool clearIfDefault = false)
    {
        if (!_layoutLoaded)
            return;

        try
        {
            if (clearIfDefault)
            {
                var existing = await FilesClient.ResolvePathAsync(LayoutFilePath, CancellationToken.None);
                if (existing.Success && existing.Value is not null && !existing.Value.IsFolder)
                    await FilesClient.DeleteAsync(existing.Value.Id, CancellationToken.None);
                return;
            }

            var snapshot = new DockLayoutSnapshot(_root, _panes);
            var json = JsonSerializer.Serialize(snapshot, new JsonSerializerOptions { WriteIndented = false });
            await FilesClient.WriteTextFileAsync(LayoutFilePath, json, "application/json", CancellationToken.None);
        }
        catch
        {
            // Layout persistence is best-effort only.
        }
    }

    private sealed class BoundingRect
    {
        public double Width { get; set; }
        public double Height { get; set; }
    }

    private void HandleWorkspaceTourRequested(string targetPaneKind)
    {
        StartTourSequence(new[] { targetPaneKind });
    }

    private void HandleWorkspaceTourSequenceRequested(IReadOnlyList<string> targetPaneKinds)
    {
        StartTourSequence(targetPaneKinds);
    }

    // User-paced, not timed: a fixed 2.2-second auto-advance either flashed
    // by before anyone finished reading, or sat around annoyingly after they
    // already got it -- there's no duration that's right for everyone.
    // Filtering to only kinds that actually resolve to a real pane up front
    // means the step count shown to the user (e.g. "2 of 4") is accurate,
    // not counting steps that will silently no-op.
    private void StartTourSequence(IReadOnlyList<string> targetPaneKinds)
    {
        var resolvable = targetPaneKinds.Where(kind => FindPaneForTour(kind) is not null).ToList();
        if (resolvable.Count == 0)
            return;

        _tourSteps = resolvable;
        _tourStepIndex = 0;
        ApplyTourStep();
    }

    private void ApplyTourStep()
    {
        if (_tourSteps is null || _tourStepIndex < 0 || _tourStepIndex >= _tourSteps.Count)
        {
            EndTour();
            return;
        }

        var targetPaneKind = _tourSteps[_tourStepIndex];
        var targetPane = FindPaneForTour(targetPaneKind);
        if (targetPane is null)
        {
            AdvanceTour();
            return;
        }

        _highlightedPaneId = targetPane.Id;
        (_tourTitle, _tourBody) = TourContentFor(targetPaneKind);
        var targetGroup = DockTree.FindGroupContainingPane(_root, targetPane.Id);
        if (targetGroup is not null)
        {
            targetGroup.ActiveIndex = targetGroup.PaneIds.IndexOf(targetPane.Id);
        }

        _ = SaveLayoutAsync();
        StateHasChanged();
    }

    private void AdvanceTour()
    {
        if (_tourSteps is null)
            return;

        _tourStepIndex++;
        ApplyTourStep();
    }

    private void EndTour()
    {
        _tourSteps = null;
        _tourStepIndex = 0;
        _highlightedPaneId = null;
        _tourTitle = null;
        _tourBody = null;
        StateHasChanged();
    }

    private PaneDescriptor? FindPaneForTour(string targetPaneKind)
    {
        if (string.IsNullOrWhiteSpace(targetPaneKind))
            return null;

        var kind = targetPaneKind.Trim().ToLowerInvariant();
        return kind switch
        {
            "files" => _panes.Values.FirstOrDefault(p => p.Kind == "files"),
            "graph" => _panes.Values.FirstOrDefault(p => p.Kind == "graph"),
            "editor" => _panes.Values.FirstOrDefault(p => p.Kind == "editor"),
            "log" or "console" => _panes.Values.FirstOrDefault(p => p.Kind == "console"),
            "data" => _panes.Values.FirstOrDefault(p => p.Kind == "data"),
            "flow" or "spinoza" or "node" or "nodes" or "visual spinoza" => _panes.Values.FirstOrDefault(p => p.Kind == "flow"),
            "chat" => _panes.Values.FirstOrDefault(p => p.Kind == "chat" && string.Equals(p.ChatPersona, "ibis", StringComparison.OrdinalIgnoreCase)),
            "seshat" => _panes.Values.FirstOrDefault(p => p.Kind == "chat" && string.Equals(p.ChatPersona, "seshat", StringComparison.OrdinalIgnoreCase)),
            _ => null
        };
    }

    // In-place explanation card shown alongside the gold highlight ring -- a
    // chat message announcing "I'll show you Files, Editor..." isn't enough
    // on its own, since the user is reading it in the chat pane while the
    // highlight is somewhere else on screen. This puts the "what is this and
    // why do I care" answer directly on the thing being highlighted, with
    // enough substance to actually explain the pane rather than just label it.
    private static (string Title, string Body) TourContentFor(string targetPaneKind)
    {
        var kind = targetPaneKind.Trim().ToLowerInvariant();
        return kind switch
        {
            "files" => ("Files", "Cloud storage for your scripts and data, backed by S3 and tied to your account. Upload, browse, and edit files here, then reference them from Visual Spinoza or the Editor."),
            "editor" => ("Editor", "Open and edit any file directly, with syntax highlighting for Spinoza and other common formats. Good for hand-writing or fine-tuning a program before running it."),
            "flow" or "spinoza" or "node" or "nodes" or "visual spinoza" => ("Visual Spinoza", "Build math programs by wiring nodes together instead of writing code by hand. Sources define the data, Constants hold reusable values, Transforms and Filters shape it, and Integrators run real Euler/RK4 simulations."),
            "graph" => ("Graph", "Live plots and simulation output land here. Every Visual Spinoza run, and every graph the AI creates through Chat, renders in a pane like this one."),
            "data" => ("Data", "A structured table view for inspecting results as rows and columns, when a plot isn't the right shape for what you're looking at."),
            "log" or "console" => ("Log", "Execution output, compile warnings, and errors from everything you run in the workspace show up here first if something isn't working."),
            "chat" => ("Ibis", "That's me — the free workspace guide. Ask me for a tour, to find a specific pane, or general help getting oriented. I don't need a key."),
            "seshat" => ("Seshat", "The BYOK math professor pane. Add your own OpenAI key in AI Setup to unlock deeper math reasoning, tutoring, and file-backed analysis."),
            _ => ("Workspace", "This is part of the DjeLab workspace.")
        };
    }

    private static bool HasRenderableLayout(DockNode root, Dictionary<string, PaneDescriptor> panes)
    {
        if (panes.Count == 0) return false;
        if (root is not SplitNode split || split.Children.Count == 0) return false;
        return split.Children.Any(child => HasRenderableNode(child, panes));
    }

    private static bool HasRenderableNode(DockNode node, Dictionary<string, PaneDescriptor> panes)
    {
        if (node is TabGroupNode group)
            return group.PaneIds.Any(panes.ContainsKey);

        if (node is SplitNode split)
            return split.Children.Any(child => HasRenderableNode(child, panes));

        return false;
    }

    // One-time relabel for layouts saved before the node editor was renamed
    // from "Flow" to "Visual Spinoza" -- the Kind string ("flow") is left
    // alone since it's load-bearing (DockNodeView's component switch, the
    // persisted layout JSON), only the user-visible Title changes, and only
    // for panes still carrying the old default title (a user who renamed
    // their own pane keeps whatever they chose).
    private void RenameLegacyFlowPanes()
    {
        foreach (var pane in _panes.Values)
        {
            if (pane.Kind == "flow" && pane.Title == "Flow")
                pane.Title = "Visual Spinoza";
        }
    }

    private void EnsureAssistantChatPanes()
    {
        var ibis = _panes.Values.FirstOrDefault(p => p.Kind == "chat" && string.Equals(p.ChatPersona, "ibis", StringComparison.OrdinalIgnoreCase));
        var seshat = _panes.Values.FirstOrDefault(p => p.Kind == "chat" && string.Equals(p.ChatPersona, "seshat", StringComparison.OrdinalIgnoreCase));
        var firstChat = _panes.Values.FirstOrDefault(p => p.Kind == "chat");

        if (ibis is null && firstChat is not null)
        {
            firstChat.ChatPersona = "ibis";
            firstChat.Title = "Ibis";
            ibis = firstChat;
        }

        if (ibis is null)
        {
            ibis = new PaneDescriptor
            {
                Title = "Ibis",
                Kind = "chat",
                AccentColor = "#7dd3fc",
                ChatPersona = "ibis"
            };
            InsertPane(ibis);
        }

        if (seshat is null)
        {
            seshat = new PaneDescriptor
            {
                Title = "Seshat",
                Kind = "chat",
                AccentColor = "#e8b354",
                ChatPersona = "seshat"
            };
            InsertPane(seshat);
        }
    }
}
