@using Djehuti.DjeLab.Services
@implements IAsyncDisposable
@inject IJSRuntime JS
@inject WorkspaceActions Actions

<div class="dock-workspace" @ref="_containerRef"
     @onpointermove="OnContainerPointerMove" @onpointerup="OnContainerPointerUp" @onpointerleave="OnContainerPointerUp">
    <div class="dock-toolbar">
        <span class="dock-toolbar-title">Workspace <span class="dock-toolbar-hint">— prototype, drag tabs and dividers, not yet saved</span></span>
        <div class="dock-toolbar-actions">
            @if (_closedPanes.Count > 0)
            {
                <select class="dock-reopen-select" @onchange="OnReopenSelected">
                    <option value="">Reopen…</option>
                    @for (var i = 0; i < _closedPanes.Count; i++)
                    {
                        var index = i;
                        <option value="@index">@_closedPanes[index].Title</option>
                    }
                </select>
            }
            <button type="button" class="dock-reset-btn" @onclick="ResetLayout">Reset layout</button>
        </div>
    </div>
    <div class="dock-canvas">
        <DockNodeView Node="_root" Panes="_panes"
                      DraggingPaneId="_draggingPaneId"
                      OnBeginResize="BeginResize"
                      OnTabDragStart="BeginDragPane"
                      OnTabActivate="ActivatePane"
                      OnDropOnTabStrip="HandleDropOnTabStrip"
                      OnDropOnBody="HandleDropOnBody"
                      OnDragEnd="EndDragPane"
                      OnClosePane="HandleClosePane" />
    </div>
</div>

@code {
    private ElementReference _containerRef;
    private IJSObjectReference? _module;

    private DockNode _root = default!;
    private Dictionary<string, PaneDescriptor> _panes = default!;
    private string? _draggingPaneId;

    private SplitNode? _resizingSplit;
    private int _resizingIndex;
    private double _resizeContainerSizePx;
    private double _resizeStartClientPos;
    private double[] _resizeStartSizes = Array.Empty<double>();
    private BoundingRect? _containerRect;

    // Closing loses whatever live state a pane had (a GraphPane's worker and
    // chart are genuinely gone -- Blazor disposes the component the instant
    // it's removed from the tree) -- this is only enough to recreate an
    // EMPTY pane of the same kind/title, a "bring back what I closed" list,
    // not an undo. Capped so it can't grow unbounded over a long session.
    private const int MaxClosedPanes = 10;
    private readonly List<ClosedPane> _closedPanes = new();
    private sealed record ClosedPane(string Title, string Kind, string AccentColor);

    protected override void OnInitialized()
    {
        (_root, _panes) = DemoLayout.CreateDefault();
        Actions.OpenGraphRequested += HandleOpenGraphRequested;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender) await RefreshContainerRectAsync();
    }

    private void ResetLayout()
    {
        (_root, _panes) = DemoLayout.CreateDefault();
        _resizingSplit = null;
        _draggingPaneId = null;
        _closedPanes.Clear();
    }

    // Graph panes are populated by the AI's run_simulation tool call -- there
    // is no manual "New Graph" / hand-type-code path anymore. Reuses
    // whichever graph pane already exists (the static one from the default
    // layout counts) rather than spawning a fresh tab on every single run:
    // mutating an EXISTING PaneDescriptor's Pending* fields and letting
    // Blazor re-render the already-mounted <GraphPane> with new parameter
    // values triggers a genuine re-run there (see GraphPane's
    // OnParametersSetAsync), without destroying and recreating the
    // component. Only creates a new pane if none exists -- e.g. the first
    // run ever, or after the user closed the last graph pane.
    private void HandleOpenGraphRequested(OpenGraphRequest request)
    {
        var existing = _panes.Values.FirstOrDefault(p => p.Kind == "graph");
        if (existing is not null)
        {
            existing.PendingRunId = request.RunId;
            existing.PendingChartType = request.ChartType;
            existing.PendingXLabel = request.XLabel;
            existing.PendingYLabel = request.YLabel;
            existing.PendingZLabel = request.ZLabel;
            existing.PendingSource = request.SpinozaSource;
            InvokeAsync(StateHasChanged);
            return;
        }

        var pane = new PaneDescriptor
        {
            Title = "Graph",
            Kind = "graph",
            AccentColor = "#3fa9f5",
            PendingRunId = request.RunId,
            PendingChartType = request.ChartType,
            PendingXLabel = request.XLabel,
            PendingYLabel = request.YLabel,
            PendingZLabel = request.ZLabel,
            PendingSource = request.SpinozaSource
        };
        InsertPane(pane);
        InvokeAsync(StateHasChanged);
    }

    // Lands a new pane as a tab alongside any existing pane of the same
    // kind (so e.g. several graphs cluster together by default); falls back
    // to the first group in the tree if none of that kind exist yet. The
    // user's normal drag-to-dock gesture (already supported) splits it into
    // its own side-by-side window afterward if they want that instead.
    private void InsertPane(PaneDescriptor pane)
    {
        _panes[pane.Id] = pane;

        var existingSameKindId = _panes.Values.FirstOrDefault(p => p.Kind == pane.Kind && p.Id != pane.Id)?.Id;
        var targetGroup = existingSameKindId is not null
            ? DockTree.FindGroupContainingPane(_root, existingSameKindId)
            : FindFirstGroup(_root);

        if (targetGroup is not null) DockTree.InsertAsTab(_root, targetGroup.Id, pane.Id);
    }

    private static TabGroupNode? FindFirstGroup(DockNode node) => node switch
    {
        TabGroupNode group => group,
        SplitNode split => split.Children.Select(FindFirstGroup).FirstOrDefault(g => g is not null),
        _ => null
    };

    private void HandleClosePane(string paneId)
    {
        if (!_panes.TryGetValue(paneId, out var pane)) return;

        _closedPanes.Insert(0, new ClosedPane(pane.Title, pane.Kind, pane.AccentColor));
        if (_closedPanes.Count > MaxClosedPanes) _closedPanes.RemoveAt(_closedPanes.Count - 1);

        _root = DockTree.RemovePane(_root, paneId);
        _panes.Remove(paneId);
    }

    private void OnReopenSelected(ChangeEventArgs e)
    {
        if (!int.TryParse(e.Value?.ToString(), out var index) || index < 0 || index >= _closedPanes.Count) return;

        var closed = _closedPanes[index];
        _closedPanes.RemoveAt(index);

        InsertPane(new PaneDescriptor { Title = closed.Title, Kind = closed.Kind, AccentColor = closed.AccentColor });
    }

    // Resize-start must be instantaneous -- a container rect fetched via JS
    // interop at drag-start races against the drag itself (pointermove can
    // fire before the interop call resolves, silently swallowing the first
    // gesture). Instead we keep a cached rect and refresh it in the
    // background after each drag starts, so the *next* drag has a fresh
    // value without ever blocking the current one.
    private void BeginResize(ResizeStart start)
    {
        if (_containerRect == null) return;

        _resizingSplit = start.Split;
        _resizingIndex = start.Index;
        _resizeContainerSizePx = start.Split.Direction == SplitDirection.Row ? _containerRect.Width : _containerRect.Height;
        _resizeStartClientPos = start.Split.Direction == SplitDirection.Row ? start.ClientX : start.ClientY;
        _resizeStartSizes = new[] { start.Split.Sizes[start.Index], start.Split.Sizes[start.Index + 1] };

        _ = RefreshContainerRectAsync();
    }

    private async Task RefreshContainerRectAsync()
    {
        _module ??= await JS.InvokeAsync<IJSObjectReference>("import", "./js/dock-interop.js");
        _containerRect = await _module.InvokeAsync<BoundingRect>("getRect", _containerRef);
    }

    private void OnContainerPointerMove(PointerEventArgs e)
    {
        if (_resizingSplit == null || _resizeContainerSizePx <= 0) return;

        var clientPos = _resizingSplit.Direction == SplitDirection.Row ? e.ClientX : e.ClientY;
        var deltaFrac = (clientPos - _resizeStartClientPos) / _resizeContainerSizePx;

        var newA = _resizeStartSizes[0] + deltaFrac;
        var newB = _resizeStartSizes[1] - deltaFrac;
        const double min = 0.08;
        if (newA < min) { newB -= (min - newA); newA = min; }
        if (newB < min) { newA -= (min - newB); newB = min; }
        if (newA < min || newB < min) return;

        _resizingSplit.Sizes[_resizingIndex] = newA;
        _resizingSplit.Sizes[_resizingIndex + 1] = newB;
        StateHasChanged();
    }

    private void OnContainerPointerUp(PointerEventArgs e)
    {
        _resizingSplit = null;
    }

    private void BeginDragPane(string paneId) => _draggingPaneId = paneId;
    private void EndDragPane() => _draggingPaneId = null;

    private void ActivatePane(TabActivate activate)
    {
        activate.Group.ActiveIndex = activate.Group.PaneIds.IndexOf(activate.PaneId);
    }

    private void HandleDropOnTabStrip(TabStripDrop drop)
    {
        if (_draggingPaneId == null) return;
        _root = DockTree.MoveToTabStrip(_root, drop.TargetGroupId, _draggingPaneId, drop.InsertIndex);
        _draggingPaneId = null;
    }

    private void HandleDropOnBody(BodyDrop drop)
    {
        if (_draggingPaneId == null) return;
        _root = DockTree.MoveToZone(_root, drop.TargetGroupId, _draggingPaneId, drop.Zone);
        _draggingPaneId = null;
    }

    public async ValueTask DisposeAsync()
    {
        Actions.OpenGraphRequested -= HandleOpenGraphRequested;
        if (_module != null) await _module.DisposeAsync();
    }

    private sealed class BoundingRect
    {
        public double Width { get; set; }
        public double Height { get; set; }
    }
}
