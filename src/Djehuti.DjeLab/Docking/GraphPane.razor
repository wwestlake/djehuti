@using System.Text.Json
@using Djehuti.DjeLab.Services
@using Djehuti.DjeLab.Components
@implements IAsyncDisposable
@inject IJSRuntime JS
@inject NavigationManager Nav
@inject DjeLabFilesClient FilesClient
@inject WorkspaceActions Actions

<div class="graph-pane">
    @if (!_hasRun)
    {
        <div class="graph-empty">
            <p>Nothing plotted yet.</p>
            <p class="graph-empty-hint">Ask the AI to graph or simulate something in Chat.</p>
        </div>
    }
    else
    {
        @if (_hasRenderDescriptors)
        {
            <div class="graph-renders">
                <RenderHost Engine="_renderEngine"
                           ShowEmpty="false"
                           OnParameterChanged="HandleParameterChanged" />
            </div>
        }
        else
        {
            <div class="graph-toolbar">
                <span class="graph-summary">@_chartType &middot; x: @_xLabel &middot; y: @_yLabel@(Is3D ? $" · z: {_zLabel}" : "")</span>
                @if (_hasRun && !string.IsNullOrWhiteSpace(_source))
                {
                    <button type="button" class="files-action-btn graph-action-btn" @onclick="SaveSourceAsync" disabled="@_savingSource">Save source</button>
                }
                @if (_running)
                {
                    <button type="button" class="files-action-btn graph-action-btn" @onclick="StopRunAsync" disabled="@_stopping">Stop</button>
                }
            </div>

            <div class="graph-status-row">
                @if (_running)
                {
                    <span class="graph-status graph-status-running">Running... @_pointCount point(s)</span>
                }
                else if (_error is not null)
                {
                    <span class="graph-status graph-status-error">Run failed - @_pointCount point(s)</span>
                }
                else
                {
                    <span class="graph-status">Done - @_pointCount point(s)</span>
                }
            </div>
        }
    }

    @* Plotly container: hidden when using render descriptors *@
    <div class="graph-plot-host" style="@(_hasRun && !_hasRenderDescriptors ? "" : "visibility: hidden; display: none;")" id="@_plotElementId"></div>
</div>

@code {
    [Parameter] public string PaneId { get; set; } = "";
    [Parameter] public string? PendingRunId { get; set; }
    [Parameter] public string? PendingChartType { get; set; }
    [Parameter] public string? PendingXLabel { get; set; }
    [Parameter] public string? PendingYLabel { get; set; }
    [Parameter] public string? PendingZLabel { get; set; }
    [Parameter] public string? PendingSource { get; set; }
    [Parameter] public string? PendingRuntimeInputJson { get; set; }

    private string _plotElementId = "";
    private SpinozaWorkerClient? _worker;
    private IJSObjectReference? _plotly;
    private RenderEngine? _renderEngine;

    private string _chartType = "line";
    private string _xLabel = "x";
    private string _yLabel = "y";
    private string _zLabel = "z";
    private string _source = "";
    private bool _hasRun;
    private bool _running;
    private bool _stopping;
    private bool _savingSource;
    private int _pointCount;
    private string? _error;
    private string? _saveStatus;
    private bool _chartCreated;
    private string? _lastRunId;
    private string? _activeRunId;
    private bool _needsResize;
    private bool _hasRenderDescriptors;
    private readonly object _emitLock = new();
    private readonly List<JsonElement> _pendingEmits = new();
    private bool _emitFlushScheduled;
    private const int EmitFlushDelayMs = 50;
    private const int EmitFlushBatchSize = 25;

    private bool Is3D => _chartType is "scatter3d" or "surface";

    protected override void OnInitialized()
    {
        _plotElementId = $"plot-{PaneId}";
        _worker = new SpinozaWorkerClient(JS, Nav);
        Actions.StopCurrentGraphRunRequested += HandleStopRequested;
    }

    protected override async Task OnParametersSetAsync()
    {
        // This pane is reused across multiple runs now -- DockWorkspace
        // mutates an EXISTING PaneDescriptor's Pending* fields rather than
        // creating a new pane each time, so this method fires again on
        // every subsequent AI-triggered run, not just the first. The guard
        // is "is this a genuinely new run" (a fresh PendingRunId), not "has
        // this pane ever run before" -- it can also fire for unrelated
        // parent re-renders, where PendingRunId is unchanged and this must
        // stay a no-op.
        if (PendingRunId is null || PendingRunId == _lastRunId || string.IsNullOrWhiteSpace(PendingSource)) return;
        _lastRunId = PendingRunId;

        _chartType = PendingChartType ?? "line";
        _xLabel = PendingXLabel ?? "x";
        _yLabel = PendingYLabel ?? "y";
        _zLabel = string.IsNullOrWhiteSpace(PendingZLabel) ? "z" : PendingZLabel;
        Actions.AppendConsole("Graph", $"Starting {_chartType} run for {_xLabel}/{_yLabel}{(Is3D ? $"/{_zLabel}" : "")}.");

        await RunAsync(PendingRunId, PendingSource, PendingRuntimeInputJson);
    }

    private async Task RunAsync(string runId, string source, string? runtimeInputJson)
    {
        if (_worker is null) return;

        // A reused pane could in principle receive a new run while the
        // previous one is still executing (e.g. two run_simulation calls in
        // quick succession) -- the worker's own thread would just queue the
        // second 'run' message behind the first, but both would end up
        // emitting onto the SAME chart element, interleaved. Stopping first
        // guarantees a clean slate; the old run's worker is torn down and a
        // fresh one boots for the new run.
        if (_running) await _worker.StopAsync();

        // Preserve RenderEngine between runs, but clear descriptors
        // This allows parameter values to flow back to the program on re-run
        bool isRerun = _renderEngine is not null && _hasRenderDescriptors;
        if (!isRerun)
        {
            _renderEngine = new RenderEngine();
            _hasRenderDescriptors = false;
        }
        else
        {
            // Clear descriptors but preserve parameter values for next run
            _renderEngine?.Reset();
        }

        _plotly ??= await JS.InvokeAsync<IJSObjectReference>("import", "./js/plotly-interop.js");
        await _plotly.InvokeVoidAsync("createChart", _plotElementId, _chartType, _xLabel, _yLabel, _zLabel);
        _chartCreated = true;
        _activeRunId = runId;
        Actions.BeginGraphDataRun(runId, PaneId, _chartType, _xLabel, _yLabel, _zLabel);

        _hasRun = true;
        _running = true;
        _stopping = false;
        _pointCount = 0;
        _error = null;
        _source = source;
        _needsResize = true;
        StateHasChanged();

        // Serialize RenderEngine parameters to JSON for the worker
        var parametersJson = _renderEngine?.ParameterValues.Count > 0
            ? System.Text.Json.JsonSerializer.Serialize(
                _renderEngine.ParameterValues.ToDictionary(kvp => kvp.Key, kvp => kvp.Value))
            : null;

        var outcome = await _worker.RunAsync(source, OnEmit, runtimeInputJson, parametersJson);

        _running = false;
        _stopping = false;
        await FlushPendingEmitsAsync();
        _error = outcome.Success ? null : outcome.Error;
        StateHasChanged();

        Actions.CompleteGraphDataRun(runId, new GraphRunOutcome(outcome.Success, _pointCount, outcome.Error));
        Actions.ReportOutcome(runId, new GraphRunOutcome(outcome.Success, _pointCount, outcome.Error));
        Actions.AppendConsole("Graph", outcome.Success
            ? $"Run completed with {_pointCount} point(s)."
            : $"Run failed after {_pointCount} point(s): {outcome.Error}", outcome.Success ? "info" : "error");
        _activeRunId = null;
    }

    private async Task StopRunAsync()
    {
        if (_worker is null || !_running || _stopping)
            return;

        _stopping = true;
        StateHasChanged();

        Actions.AppendConsole("Graph", "Stop requested.");
        await _worker.StopAsync();
        await FlushPendingEmitsAsync();
    }

    private async Task SaveSourceAsync()
    {
        if (string.IsNullOrWhiteSpace(_source) || _savingSource)
            return;

        var defaultPath = $"/djelab/generated/{_chartType}-{DateTime.UtcNow:yyyyMMdd-HHmmss}.fsx";
        var path = await JS.InvokeAsync<string?>("prompt", "Save the current program to which file path?", defaultPath);
        if (string.IsNullOrWhiteSpace(path))
            return;

        _savingSource = true;
        _saveStatus = null;
        StateHasChanged();

        try
        {
            var saveResult = await FilesClient.WriteTextFileAsync(path, _source, "text/plain");
            _saveStatus = saveResult.Success && saveResult.Value is not null
                ? $"Saved program to {saveResult.Value.Path}."
                : saveResult.Error ?? "Could not save the program.";
            if (saveResult.Success && saveResult.Value is not null)
            {
                Actions.NotifyFilesChanged();
                Actions.AppendConsole("Graph", $"Saved program source to {saveResult.Value.Path}.");
            }
        }
        catch (Exception ex)
        {
            _saveStatus = ex.Message;
        }
        finally
        {
            _savingSource = false;
            StateHasChanged();
        }
    }

    private void OnEmit(JsonElement point)
    {
        // Check if this is a render descriptor (has a "type" property for render types like "graph", "slider", etc.)
        if (point.ValueKind == JsonValueKind.Object && point.TryGetProperty("type", out var typeElement) && typeElement.ValueKind == JsonValueKind.String)
        {
            var typeStr = typeElement.GetString();
            if (!string.IsNullOrWhiteSpace(typeStr) && IsRenderType(typeStr))
            {
                HandleRenderDescriptor(point);
                return;
            }
        }

        // Otherwise treat it as a graph data point (traditional behavior)
        var shouldFlushNow = false;
        lock (_emitLock)
        {
            _pendingEmits.Add(point);
            _pointCount++;
            if (_emitFlushScheduled) return;
            _emitFlushScheduled = true;
            shouldFlushNow = _pendingEmits.Count >= EmitFlushBatchSize;
        }

        if (shouldFlushNow) _ = FlushPendingEmitsAsync();
        else _ = FlushPendingEmitsLaterAsync();
    }

    private bool IsRenderType(string type) => type is
        "graph" or "button" or "slider" or "input" or "notation" or "piano" or "fretboard" or "music" or "math" or "text" or "container";

    private void HandleRenderDescriptor(JsonElement descriptorJson)
    {
        if (_renderEngine is null) return;

        var descriptor = RenderDescriptor.TryDeserialize(descriptorJson);
        if (descriptor is not null)
        {
            _renderEngine.AddDescriptor(descriptor);
            _hasRenderDescriptors = true;
            _pointCount++;
            StateHasChanged();
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_needsResize && _plotly is not null)
        {
            _needsResize = false;
            try
            {
                await _plotly.InvokeVoidAsync("resize", _plotElementId);
            }
            catch (JSDisconnectedException)
            {
                // The chart will be recreated on the next run if the browser
                // is already gone.
            }
        }
    }

    public async ValueTask DisposeAsync()
    {
        Actions.StopCurrentGraphRunRequested -= HandleStopRequested;
        if (_worker is not null) await _worker.DisposeAsync();
        if (_plotly is not null)
        {
            if (_chartCreated)
            {
                try { await _plotly.InvokeVoidAsync("dispose", _plotElementId); }
                catch (JSDisconnectedException) { /* app is tearing down; nothing to clean up client-side for */ }
            }
            await _plotly.DisposeAsync();
        }
    }

    private void HandleStopRequested()
    {
        if (_running && !_stopping)
            _ = StopRunAsync();
    }

    private void HandleParameterChanged((string Name, object Value) param)
    {
        // Parameter change detected from RenderHost (slider, button, input).
        // Trigger re-run with updated parameters.
        if (_running || string.IsNullOrWhiteSpace(_source) || _activeRunId is null)
            return;

        _ = RunAsync(_activeRunId, _source, null);
    }

    private async Task FlushPendingEmitsLaterAsync()
    {
        await Task.Delay(EmitFlushDelayMs);
        await FlushPendingEmitsAsync();
    }

    private async Task FlushPendingEmitsAsync()
    {
        List<JsonElement> batch;
        lock (_emitLock)
        {
            if (_pendingEmits.Count == 0)
            {
                _emitFlushScheduled = false;
                return;
            }

            batch = new List<JsonElement>(_pendingEmits);
            _pendingEmits.Clear();
            _emitFlushScheduled = false;
        }

        if (_activeRunId is not null)
            Actions.ReportGraphDataEmits(_activeRunId, batch);

        if (_plotly is not null)
        {
            try
            {
                await _plotly.InvokeVoidAsync("addPoints", _plotElementId, _chartType, batch);
            }
            catch (JSDisconnectedException)
            {
                // The browser is already gone; the worker result still gets
                // cleaned up and the next run will recreate the chart.
            }
        }

        await InvokeAsync(StateHasChanged);

        lock (_emitLock)
        {
            if (_pendingEmits.Count > 0 && !_emitFlushScheduled)
            {
                _emitFlushScheduled = true;
                _ = FlushPendingEmitsLaterAsync();
            }
        }
    }
}

