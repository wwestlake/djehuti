@using System.Text.Json
@using Djehuti.DjeLab.Services
@implements IAsyncDisposable
@inject IJSRuntime JS
@inject NavigationManager Nav
@inject WorkspaceActions Actions

<div class="graph-pane">
    @if (!_hasRun)
    {
        <div class="graph-empty">
            <p>Nothing plotted yet.</p>
            <p class="graph-empty-hint">Ask the AI to graph or simulate something in Chat.</p>
        </div>
    }
    else
    {
        <div class="graph-toolbar">
            <span class="graph-summary">@_chartType &middot; x: @_xLabel &middot; y: @_yLabel@(Is3D ? $" · z: {_zLabel}" : "")</span>
        </div>

        <div class="graph-status-row">
            @if (_running)
            {
                <span class="graph-status graph-status-running">Running… @_pointCount point(s)</span>
            }
            else if (_error is not null)
            {
                <span class="graph-status graph-status-error">@_error</span>
            }
            else
            {
                <span class="graph-status">Done — @_pointCount point(s)</span>
            }
        </div>

        <div class="graph-plot-host" id="@_plotElementId"></div>
    }
</div>

@code {
    [Parameter] public string PaneId { get; set; } = "";
    [Parameter] public string? PendingRunId { get; set; }
    [Parameter] public string? PendingChartType { get; set; }
    [Parameter] public string? PendingXLabel { get; set; }
    [Parameter] public string? PendingYLabel { get; set; }
    [Parameter] public string? PendingZLabel { get; set; }
    [Parameter] public string? PendingSource { get; set; }

    private string _plotElementId = "";
    private SpinozaWorkerClient? _worker;
    private IJSObjectReference? _plotly;

    private string _chartType = "line";
    private string _xLabel = "x";
    private string _yLabel = "y";
    private string _zLabel = "z";
    private bool _hasRun;
    private bool _running;
    private int _pointCount;
    private string? _error;
    private bool _chartCreated;
    private bool _autoRunStarted;

    private bool Is3D => _chartType is "scatter3d" or "surface";

    protected override void OnInitialized()
    {
        _plotElementId = $"plot-{PaneId}";
        _worker = new SpinozaWorkerClient(JS, Nav);
    }

    protected override async Task OnParametersSetAsync()
    {
        // A graph pane is only ever auto-run once, the instant the AI's
        // pending source/chart-type parameters first arrive -- this method
        // can fire again later for unrelated reasons (parent re-render), so
        // the guard is load-bearing, not just an optimization.
        if (_autoRunStarted || PendingRunId is null || string.IsNullOrWhiteSpace(PendingSource)) return;
        _autoRunStarted = true;

        _chartType = PendingChartType ?? "line";
        _xLabel = PendingXLabel ?? "x";
        _yLabel = PendingYLabel ?? "y";
        _zLabel = string.IsNullOrWhiteSpace(PendingZLabel) ? "z" : PendingZLabel;

        await RunAsync(PendingRunId, PendingSource);
    }

    private async Task RunAsync(string runId, string source)
    {
        if (_worker is null) return;

        _plotly ??= await JS.InvokeAsync<IJSObjectReference>("import", "./js/plotly-interop.js");
        await _plotly.InvokeVoidAsync("createChart", _plotElementId, _chartType, _xLabel, _yLabel, _zLabel);
        _chartCreated = true;

        _hasRun = true;
        _running = true;
        _pointCount = 0;
        _error = null;
        StateHasChanged();

        var outcome = await _worker.RunAsync(source, OnEmit);

        _running = false;
        _error = outcome.Success ? null : outcome.Error;
        StateHasChanged();

        Actions.ReportOutcome(runId, new GraphRunOutcome(outcome.Success, _pointCount, outcome.Error));
    }

    private void OnEmit(JsonElement point)
    {
        _pointCount++;
        if (_plotly is not null)
        {
            _ = _plotly.InvokeVoidAsync("addPoint", _plotElementId, _chartType, point);
        }
        InvokeAsync(StateHasChanged);
    }

    public async ValueTask DisposeAsync()
    {
        if (_worker is not null) await _worker.DisposeAsync();
        if (_plotly is not null)
        {
            if (_chartCreated)
            {
                try { await _plotly.InvokeVoidAsync("dispose", _plotElementId); }
                catch (JSDisconnectedException) { /* app is tearing down; nothing to clean up client-side for */ }
            }
            await _plotly.DisposeAsync();
        }
    }
}
