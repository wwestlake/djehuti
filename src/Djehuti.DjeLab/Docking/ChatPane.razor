@using Markdig
@inject AiConfigStore ConfigStore
@inject ChatHistoryStore HistoryStore
@inject AiChatClient ChatClient
@inject IJSRuntime JS

<div class="chat-pane">
    @if (_loading)
    {
        <div class="chat-pane-loading">Loading…</div>
    }
    else if (!_hasKey)
    {
        <div class="chat-pane-empty">
            <p>No AI configured yet.</p>
            <a class="chat-pane-setup-link" href="settings">Go to AI Setup</a>
        </div>
    }
    else
    {
        <div class="chat-pane-messages" @ref="_messagesRef">
            @if (_turns.Count == 0)
            {
                <div class="chat-pane-empty-history">Ask anything about the math you're working on.</div>
            }
            @foreach (var turn in _turns)
            {
                <div class="chat-message chat-message-@turn.Role">
                    <div class="chat-message-bubble">@RenderMarkdown(turn.Content)</div>
                </div>
            }
            @if (_sending)
            {
                <div class="chat-message chat-message-assistant">
                    <div class="chat-message-bubble chat-message-pending">Thinking…</div>
                </div>
            }
            @if (_error is not null)
            {
                <div class="chat-message-system">@_error</div>
            }
        </div>

        <form class="chat-pane-input-row" @onsubmit="Send">
            <textarea @ref="_inputRef"
                      class="chat-pane-input"
                      placeholder="Ask about a math problem…"
                      value="@_input"
                      @oninput="OnInputChanged"
                      @onkeydown="OnKeyDown"></textarea>
            <div class="chat-pane-input-actions">
                <button type="submit" class="chat-pane-send" disabled="@(_sending || string.IsNullOrWhiteSpace(_input))">
                    Send
                </button>
                <button type="button" class="chat-pane-clear" @onclick="ClearChat" disabled="@_sending">
                    Clear
                </button>
            </div>
        </form>
    }
</div>

@code {
    private bool _loading = true;
    private bool _hasKey;
    private bool _sending;
    private string? _error;
    private string _apiKey = "";
    private string _model = "";
    private string _input = "";
    private List<ChatTurn> _turns = new();
    private ElementReference _messagesRef;
    private ElementReference _inputRef;
    private IJSObjectReference? _module;

    private const int InputMaxHeightPx = 260;

    // Raw HTML passthrough is disabled -- the assistant's content (and, in
    // principle, the user's own retyped/pasted content) is untrusted text
    // rendered via MarkupString, which bypasses Blazor's normal HTML
    // encoding. DisableHtml makes Markdig render literal "<...>" text
    // instead of interpreting it as HTML, closing that off.
    private static readonly MarkdownPipeline MarkdownPipeline =
        new MarkdownPipelineBuilder().UseAdvancedExtensions().DisableHtml().Build();

    private static MarkupString RenderMarkdown(string content) =>
        new(Markdown.ToHtml(content, MarkdownPipeline));

    protected override async Task OnInitializedAsync()
    {
        _apiKey = await ConfigStore.GetApiKeyAsync() ?? "";
        _model = await ConfigStore.GetModelAsync();
        _hasKey = !string.IsNullOrWhiteSpace(_apiKey);
        if (_hasKey)
        {
            _turns = await HistoryStore.GetTurnsAsync();
        }
        _loading = false;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_hasKey)
        {
            await TryInvokeJsAsync("scrollToBottom", _messagesRef);
        }
    }

    private async Task OnKeyDown(Microsoft.AspNetCore.Components.Web.KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !e.ShiftKey)
        {
            await Send();
        }
    }

    private async Task OnInputChanged(ChangeEventArgs e)
    {
        _input = e.Value?.ToString() ?? "";
        await TryInvokeJsAsync("autoGrowTextarea", _inputRef, InputMaxHeightPx);
    }

    // All JS interop for this pane is cosmetic (auto-scroll, textarea
    // sizing) -- never something the actual send/receive flow depends on.
    // A mismatch between the compiled app and a stale cached copy of
    // dock-interop.js (browsers can hold onto an old version across a
    // deploy) must never take down the chat itself, so failures here are
    // swallowed rather than left to bubble up as an unhandled exception.
    private async Task TryInvokeJsAsync(string function, params object[] args)
    {
        try
        {
            _module ??= await JS.InvokeAsync<IJSObjectReference>("import", "./js/dock-interop.js");
            await _module.InvokeVoidAsync(function, args);
        }
        catch (JSException)
        {
            _module = null; // force re-import next time, in case the cached module was the problem
        }
    }

    private async Task Send()
    {
        var text = _input.Trim();
        if (string.IsNullOrEmpty(text) || _sending) return;

        _input = "";
        _error = null;
        var history = _turns.ToList();
        _turns.Add(new ChatTurn { Role = "user", Content = text });
        _sending = true;
        StateHasChanged();

        try
        {
            await TryInvokeJsAsync("resetTextareaHeight", _inputRef);
            var reply = await ChatClient.AskAsync(_apiKey, _model, history, text);
            _turns.Add(new ChatTurn { Role = "assistant", Content = reply });
            await HistoryStore.SaveTurnsAsync(_turns);
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _sending = false;
        }
    }

    private async Task ClearChat()
    {
        _turns.Clear();
        _error = null;
        await HistoryStore.ClearAsync();
    }
}
