@using Markdig
@using System.Text.Json
@inject DjeLabFilesClient FilesClient
@inject AiConfigStore ConfigStore
@inject ChatHistoryStore HistoryStore
@inject AiChatClient ChatClient
@inject IJSRuntime JS
@inject HttpClient Http
@inject WorkspaceActions Actions

<div class="chat-pane">
    @if (_loading)
    {
        <div class="chat-pane-loading">Loading…</div>
    }
    else if (!_hasKey)
    {
        <div class="chat-pane-empty">
            <p>No AI configured yet.</p>
            <a class="chat-pane-setup-link" href="settings">Go to AI Setup</a>
        </div>
    }
    else
    {
        <div class="chat-pane-messages" @ref="_messagesRef">
            @if (_turns.Count == 0)
            {
                <div class="chat-pane-empty-history">Ask anything about the math you're working on.</div>
            }
            @foreach (var turn in _turns)
            {
                <div class="chat-message chat-message-@turn.Role">
                    <div class="chat-message-bubble">@RenderMarkdown(turn.Content)</div>
                </div>
            }
            @if (_sending)
            {
                <div class="chat-message chat-message-assistant">
                    <div class="chat-message-bubble chat-message-pending">Thinking…</div>
                </div>
            }
            @if (_error is not null)
            {
                <div class="chat-message-system">@_error</div>
            }
        </div>

        <form class="chat-pane-input-row" @onsubmit="Send">
            <textarea @ref="_inputRef"
                      class="chat-pane-input"
                      placeholder="Ask about a math problem…"
                      value="@_input"
                      @oninput="OnInputChanged"
                      @onkeydown="OnKeyDown"></textarea>
            <div class="chat-pane-input-actions">
                <button type="submit" class="chat-pane-send" disabled="@(_sending || string.IsNullOrWhiteSpace(_input))">
                    Send
                </button>
                <button type="button" class="chat-pane-clear" @onclick="ClearChat" disabled="@_sending">
                    Clear
                </button>
            </div>
        </form>
    }
</div>

@code {
    private bool _loading = true;
    private bool _hasKey;
    private bool _sending;
    private string? _error;
    private string _apiKey = "";
    private string _model = "";
    private string _input = "";
    private List<ChatTurn> _turns = new();
    private ElementReference _messagesRef;
    private ElementReference _inputRef;
    private IJSObjectReference? _module;

    private const int InputMaxHeightPx = 260;

    // Raw HTML passthrough is disabled -- the assistant's content (and, in
    // principle, the user's own retyped/pasted content) is untrusted text
    // rendered via MarkupString, which bypasses Blazor's normal HTML
    // encoding. DisableHtml makes Markdig render literal "<...>" text
    // instead of interpreting it as HTML, closing that off.
    private static readonly MarkdownPipeline MarkdownPipeline =
        new MarkdownPipelineBuilder().UseAdvancedExtensions().DisableHtml().Build();

    // Normalizing again here (AiChatClient already does it once when a reply
    // first arrives) is deliberate belt-and-suspenders: it also retroactively
    // fixes any turn already sitting in saved chat history from before this
    // existed, and guards against the receive-time pass being bypassed for
    // any reason.
    private static MarkupString RenderMarkdown(string content) =>
        new(Markdown.ToHtml(MathDelimiterNormalizer.Normalize(content), MarkdownPipeline));

    protected override async Task OnInitializedAsync()
    {
        _apiKey = await ConfigStore.GetApiKeyAsync() ?? "";
        _model = await ConfigStore.GetModelAsync();
        _hasKey = !string.IsNullOrWhiteSpace(_apiKey);
        if (_hasKey)
        {
            _turns = await HistoryStore.GetTurnsAsync();
        }
        _loading = false;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_hasKey)
        {
            await TryInvokeJsAsync("renderMath", _messagesRef);
            await TryInvokeJsAsync("scrollToBottom", _messagesRef);
        }
    }

    private async Task OnKeyDown(Microsoft.AspNetCore.Components.Web.KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !e.ShiftKey)
        {
            await Send();
        }
    }

    private async Task OnInputChanged(ChangeEventArgs e)
    {
        _input = e.Value?.ToString() ?? "";
        await TryInvokeJsAsync("autoGrowTextarea", _inputRef, InputMaxHeightPx);
    }

    // All JS interop for this pane is cosmetic (auto-scroll, textarea
    // sizing) -- never something the actual send/receive flow depends on.
    // A mismatch between the compiled app and a stale cached copy of
    // dock-interop.js (browsers can hold onto an old version across a
    // deploy) must never take down the chat itself, so failures here are
    // swallowed rather than left to bubble up as an unhandled exception.
    private async Task TryInvokeJsAsync(string function, params object[] args)
    {
        try
        {
            _module ??= await JS.InvokeAsync<IJSObjectReference>("import", "./js/dock-interop.js");
            await _module.InvokeVoidAsync(function, args);
        }
        catch (JSException)
        {
            _module = null; // force re-import next time, in case the cached module was the problem
        }
    }

    // Built once per pane instance (captures Http/Actions via closure) --
    // these are what actually makes AiChatClient's generic tool loop DO
    // anything in this app; AiChatClient itself only knows the OpenAI
    // protocol, not what search_math_references or run_simulation mean.
    private IReadOnlyDictionary<string, ToolHandler> ToolHandlers => new Dictionary<string, ToolHandler>
    {
        ["search_math_references"] = SearchMathReferencesAsync,
        ["run_simulation"] = RunSimulationAsync,
        ["manage_file_data"] = ManageFileDataAsync
    };

    private async Task<string> ManageFileDataAsync(string argumentsJson)
    {
        using var args = JsonDocument.Parse(argumentsJson);
        string Get(string name, string fallback = "") =>
            args.RootElement.TryGetProperty(name, out var v) ? v.GetString() ?? fallback : fallback;

        var action = Get("action").Trim().ToLowerInvariant();
        var path = Get("path");
        var content = Get("content");
        var contentType = Get("contentType", "text/plain");

        if (string.IsNullOrWhiteSpace(path))
            return "No path provided.";

        switch (action)
        {
            case "list":
            {
                var entries = await FilesClient.ListFolderAsync(path);
                return JsonSerializer.Serialize(new
                {
                    action,
                    path,
                    entries = entries.Select(entry => new
                    {
                        Id = entry.Id,
                        IsFolder = entry.IsFolder,
                        Path = entry.Path,
                        Name = entry.Name,
                        ContentType = entry.ContentType,
                        SizeBytes = entry.SizeBytes
                    })
                });
            }
            case "read":
            {
                var readResult = await FilesClient.ReadTextFileAsync(path);
                if (!readResult.Success || readResult.Value is null)
                    return readResult.Error ?? "Could not read that file.";

                var resolved = await FilesClient.ResolvePathAsync(path);
                if (!resolved.Success || resolved.Value is null)
                    return resolved.Error ?? "Could not resolve that file.";

                return JsonSerializer.Serialize(SummarizeFile(resolved.Value, readResult.Value));
            }
            case "tree":
            {
                var treeResult = await FilesClient.ReadStructuredDataAsync(path);
                if (!treeResult.Success || treeResult.Value is null)
                    return treeResult.Error ?? "Could not read that structure.";

                return treeResult.Value;
            }
            case "write":
            {
                if (string.IsNullOrWhiteSpace(content))
                    return "No content provided.";

                var normalizedContentType = string.IsNullOrWhiteSpace(contentType) ? "text/plain" : contentType;
                var writeResult = await FilesClient.WriteTextFileAsync(path, content, normalizedContentType);
                if (!writeResult.Success || writeResult.Value is null)
                    return writeResult.Error ?? "Could not write that file.";

                return JsonSerializer.Serialize(new
                {
                    action,
                    path = writeResult.Value.Path,
                    Id = writeResult.Value.Id,
                    ContentType = writeResult.Value.ContentType,
                    SizeBytes = writeResult.Value.SizeBytes
                });
            }
            default:
                return "Unknown file action. Use list, read, tree, or write.";
        }
    }

    private async Task<string> SearchMathReferencesAsync(string argumentsJson)
    {
        using var args = JsonDocument.Parse(argumentsJson);
        var query = args.RootElement.TryGetProperty("query", out var q) ? q.GetString() ?? "" : "";
        if (string.IsNullOrWhiteSpace(query)) return "No query provided.";

        var response = await Http.GetAsync($"/djehuti/api/djelab/search-references?q={Uri.EscapeDataString(query)}");
        if (!response.IsSuccessStatusCode) return $"Search failed with HTTP {(int)response.StatusCode}.";

        using var results = JsonDocument.Parse(await response.Content.ReadAsStringAsync());
        if (results.RootElement.ValueKind != JsonValueKind.Array || results.RootElement.GetArrayLength() == 0)
            return "No matching reference material found.";

        var parts = results.RootElement.EnumerateArray().Select(hit =>
        {
            var title = hit.TryGetProperty("title", out var t) ? t.GetString() : "";
            var content = hit.TryGetProperty("content", out var c) ? c.GetString() : "";
            return $"## {title}\n{content}";
        });
        return string.Join("\n\n", parts);
    }

    private async Task<string> RunSimulationAsync(string argumentsJson)
    {
        using var args = JsonDocument.Parse(argumentsJson);
        string Get(string name, string fallback = "") =>
            args.RootElement.TryGetProperty(name, out var v) ? v.GetString() ?? fallback : fallback;

        var chartType = Get("chartType", "line");
        var xLabel = NormalizeAxisLabel(Get("xLabel", ""), chartType, axis: "x");
        var yLabel = NormalizeAxisLabel(Get("yLabel", ""), chartType, axis: "y");
        var zLabel = NormalizeAxisLabel(Get("zLabel", ""), chartType, axis: "z");
        var source = Get("spinozaSource");

        if (string.IsNullOrWhiteSpace(source)) return "No spinozaSource provided.";

        var outcome = await Actions.RunInNewGraphAsync(chartType, xLabel, yLabel, zLabel, source);
        return outcome.Success
            ? $"Ran successfully in a new {chartType} graph pane; emitted {outcome.PointCount} point(s)."
            : $"The program failed to run: {outcome.Error}";
    }

    private static string NormalizeAxisLabel(string? label, string chartType, string axis)
    {
        var trimmed = string.IsNullOrWhiteSpace(label) ? "" : label.Trim();
        if (!IsGenericAxisLabel(trimmed)) return trimmed;

        return chartType switch
        {
            "surface" => axis switch
            {
                "x" => "x position",
                "y" => "y position",
                _ => "height"
            },
            "scatter3d" => axis switch
            {
                "x" => "x position",
                "y" => "y position",
                _ => "height"
            },
            _ => axis switch
            {
                "x" => "input",
                "y" => "value",
                _ => "value"
            }
        };
    }

    private static bool IsGenericAxisLabel(string label) =>
        string.IsNullOrWhiteSpace(label) ||
        label is "x" or "y" or "z" or "X" or "Y" or "Z" or "x-axis" or "y-axis" or "z-axis";

    private static object SummarizeFile(DjeLabFileEntry entry, string content)
    {
        var kind = DetectKind(entry, content);
        var preview = content.Length > 20000 ? content[..20000] : content;
        var truncated = entry.SizeBytes is long size && size > content.Length;

        return kind switch
        {
            "json" => SummarizeJson(entry, content, preview, truncated),
            "csv" => SummarizeCsv(entry, content, preview, truncated),
            _ => new
            {
                kind = "text",
                Path = entry.Path,
                ContentType = entry.ContentType,
                SizeBytes = entry.SizeBytes,
                preview,
                truncated = truncated || content.Length > preview.Length
            }
        };
    }

    private static object SummarizeJson(DjeLabFileEntry entry, string content, string preview, bool truncated)
    {
        try
        {
            using var doc = JsonDocument.Parse(content);
            if (doc.RootElement.ValueKind == JsonValueKind.Array)
            {
                var sample = doc.RootElement.EnumerateArray().Take(5).Select(item => item.ValueKind == JsonValueKind.Object
                    ? item.EnumerateObject().Take(20).ToDictionary(prop => prop.Name, prop => prop.Value.ToString())
                    : new Dictionary<string, string> { ["value"] = item.ToString() }).ToArray();

                return new
                {
                    kind = "json-array",
                    Path = entry.Path,
                    ContentType = entry.ContentType,
                    SizeBytes = entry.SizeBytes,
                    count = doc.RootElement.GetArrayLength(),
                    sample,
                    preview = preview.Length == content.Length ? preview : preview + "\n...",
                    truncated
                };
            }

            if (doc.RootElement.ValueKind == JsonValueKind.Object)
            {
                return new
                {
                    kind = "json-object",
                    Path = entry.Path,
                    ContentType = entry.ContentType,
                    SizeBytes = entry.SizeBytes,
                    keys = doc.RootElement.EnumerateObject().Select(prop => prop.Name).Take(50).ToArray(),
                    preview = preview.Length == content.Length ? preview : preview + "\n...",
                    truncated
                };
            }
        }
        catch (JsonException)
        {
            // Fall through to generic text summary.
        }

        return new
        {
            kind = "json-text",
            Path = entry.Path,
            ContentType = entry.ContentType,
            SizeBytes = entry.SizeBytes,
            preview = preview.Length == content.Length ? preview : preview + "\n...",
            truncated
        };
    }

    private static object SummarizeCsv(DjeLabFileEntry entry, string content, string preview, bool truncated)
    {
        var lines = content.Split(['\r', '\n'], StringSplitOptions.RemoveEmptyEntries);
        var headers = lines.Length > 0 ? lines[0].Split(',').Select(x => x.Trim()).ToArray() : Array.Empty<string>();
        var sampleRows = lines.Skip(1).Take(5).Select(line => line.Split(',').Select(x => x.Trim()).ToArray()).ToArray();

        return new
        {
            kind = "csv",
            Path = entry.Path,
            ContentType = entry.ContentType,
            SizeBytes = entry.SizeBytes,
            headers,
            rowCount = Math.Max(0, lines.Length - 1),
            sampleRows,
            preview = preview.Length == content.Length ? preview : preview + "\n...",
            truncated
        };
    }

    private static string DetectKind(DjeLabFileEntry entry, string content)
    {
        var type = (entry.ContentType ?? "").ToLowerInvariant();
        if (type.Contains("json")) return "json";
        if (type.Contains("csv") || entry.Path.EndsWith(".csv", StringComparison.OrdinalIgnoreCase)) return "csv";
        if (entry.Path.EndsWith(".json", StringComparison.OrdinalIgnoreCase)) return "json";
        return "text";
    }

    private async Task Send()
    {
        var text = _input.Trim();
        if (string.IsNullOrEmpty(text) || _sending) return;

        _input = "";
        _error = null;
        var history = _turns.ToList();
        _turns.Add(new ChatTurn { Role = "user", Content = text });
        _sending = true;
        StateHasChanged();

        try
        {
            await TryInvokeJsAsync("resetTextareaHeight", _inputRef);
            var reply = await ChatClient.AskAsync(_apiKey, _model, history, text, ToolHandlers);
            LogMathDelimiterDiagnostics(reply);
            _turns.Add(new ChatTurn { Role = "assistant", Content = reply });
            await HistoryStore.SaveTurnsAsync(_turns);
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _sending = false;
        }
    }

    private async Task ClearChat()
    {
        _turns.Clear();
        _error = null;
        await HistoryStore.ClearAsync();
    }

    // Diagnostic only -- routes to the browser devtools console (Console.
    // WriteLine does this in Blazor WASM). If math delimiters ever silently
    // fail to normalize again, this shows the actual raw text directly
    // rather than needing another screenshot round-trip to guess from.
    private static void LogMathDelimiterDiagnostics(string reply)
    {
        var stillHasRawDelimiters = reply.Contains(@"\(") || reply.Contains(@"\[");
        if (stillHasRawDelimiters)
        {
            var preview = reply.Length > 200 ? reply[..200] + "…" : reply;
            Console.WriteLine($"[DjeLab] Reply still contains raw \\( or \\[ after normalization. Preview: {preview}");
        }
    }
}




