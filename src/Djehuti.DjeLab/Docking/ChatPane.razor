@using Markdig
@using System.Text
@using System.Text.Json
@inject DjeLabFilesClient FilesClient
@inject AiConfigStore ConfigStore
@inject ChatHistoryStore HistoryStore
@inject AiChatClient ChatClient
@inject IJSRuntime JS
@inject HttpClient Http
@inject WorkspaceActions Actions

<div class="chat-pane">
    @if (_loading)
    {
        <div class="chat-pane-loading">Loading…</div>
    }
    else if (!_hasKey)
    {
        <div class="chat-pane-empty">
            <p>No AI configured yet.</p>
            <a class="chat-pane-setup-link" href="settings">Go to AI Setup</a>
        </div>
    }
    else
    {
        <div class="chat-pane-messages" @ref="_messagesRef">
            @if (_turns.Count == 0)
            {
                <div class="chat-pane-empty-history">Ask anything about the math you're working on.</div>
            }
            @foreach (var turn in _turns)
            {
                <div class="chat-message chat-message-@turn.Role">
                    <div class="chat-message-bubble">@RenderMarkdown(turn.Content)</div>
                </div>
            }
            @if (_sending)
            {
                <div class="chat-message chat-message-assistant">
                    <div class="chat-message-bubble chat-message-pending">Thinking…</div>
                </div>
            }
            @if (_error is not null)
            {
                <div class="chat-message-system">@_error</div>
            }
        </div>

        <form class="chat-pane-input-row" @onsubmit="Send">
            <textarea @ref="_inputRef"
                      class="chat-pane-input"
                      placeholder="Ask about a math problem…"
                      value="@_input"
                      @oninput="OnInputChanged"
                      @onkeydown="OnKeyDown"></textarea>
            <div class="chat-pane-input-actions">
                @if (_sending)
                {
                    <button type="button" class="chat-pane-stop" @onclick="StopSendAsync">
                        Stop
                    </button>
                }
                else
                {
                    <button type="submit" class="chat-pane-send" disabled="@string.IsNullOrWhiteSpace(_input)">
                        Send
                    </button>
                }
                <button type="button" class="chat-pane-clear" @onclick="ClearChat" disabled="@_sending">
                    Clear
                </button>
            </div>
        </form>
    }
</div>

@code {
    private bool _loading = true;
    private bool _hasKey;
    private bool _sending;
    private string? _error;
    private string _apiKey = "";
    private string _model = "";
    private string _input = "";
    private List<ChatTurn> _turns = new();
    private ElementReference _messagesRef;
    private ElementReference _inputRef;
    private IJSObjectReference? _module;
    private CancellationTokenSource? _sendCts;

    private const int InputMaxHeightPx = 260;

    // Raw HTML passthrough is disabled -- the assistant's content (and, in
    // principle, the user's own retyped/pasted content) is untrusted text
    // rendered via MarkupString, which bypasses Blazor's normal HTML
    // encoding. DisableHtml makes Markdig render literal "<...>" text
    // instead of interpreting it as HTML, closing that off.
    private static readonly MarkdownPipeline MarkdownPipeline =
        new MarkdownPipelineBuilder().UseAdvancedExtensions().DisableHtml().Build();

    // Normalizing again here (AiChatClient already does it once when a reply
    // first arrives) is deliberate belt-and-suspenders: it also retroactively
    // fixes any turn already sitting in saved chat history from before this
    // existed, and guards against the receive-time pass being bypassed for
    // any reason.
    private static MarkupString RenderMarkdown(string content) =>
        new(Markdown.ToHtml(MathDelimiterNormalizer.Normalize(content), MarkdownPipeline));

    protected override async Task OnInitializedAsync()
    {
        _apiKey = await ConfigStore.GetApiKeyAsync() ?? "";
        _model = await ConfigStore.GetModelAsync();
        _hasKey = !string.IsNullOrWhiteSpace(_apiKey);
        if (_hasKey)
        {
            _turns = await HistoryStore.GetTurnsAsync();
        }
        _loading = false;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_hasKey)
        {
            await TryInvokeJsAsync("renderMath", _messagesRef);
            await TryInvokeJsAsync("scrollToBottom", _messagesRef);
        }
    }

    private async Task OnKeyDown(Microsoft.AspNetCore.Components.Web.KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !e.ShiftKey)
        {
            await Send();
        }
    }

    private async Task OnInputChanged(ChangeEventArgs e)
    {
        _input = e.Value?.ToString() ?? "";
        await TryInvokeJsAsync("autoGrowTextarea", _inputRef, InputMaxHeightPx);
    }

    // All JS interop for this pane is cosmetic (auto-scroll, textarea
    // sizing) -- never something the actual send/receive flow depends on.
    // A mismatch between the compiled app and a stale cached copy of
    // dock-interop.js (browsers can hold onto an old version across a
    // deploy) must never take down the chat itself, so failures here are
    // swallowed rather than left to bubble up as an unhandled exception.
    private async Task TryInvokeJsAsync(string function, params object[] args)
    {
        try
        {
            _module ??= await JS.InvokeAsync<IJSObjectReference>("import", "./js/dock-interop.js");
            await _module.InvokeVoidAsync(function, args);
        }
        catch (JSException)
        {
            _module = null; // force re-import next time, in case the cached module was the problem
        }
    }

    // Built once per pane instance (captures Http/Actions via closure) --
    // these are what actually makes AiChatClient's generic tool loop DO
    // anything in this app; AiChatClient itself only knows the OpenAI
    // protocol, not what search_math_references or run_simulation mean.
    private IReadOnlyDictionary<string, ToolHandler> ToolHandlers => new Dictionary<string, ToolHandler>
    {
        ["search_math_references"] = SearchMathReferencesAsync,
        ["validate_spinoza"] = ValidateSpinozaAsync,
        ["run_simulation"] = RunSimulationAsync,
        ["manage_file_data"] = ManageFileDataAsync
    };

    private async Task<string> ManageFileDataAsync(string argumentsJson, CancellationToken ct)
    {
        using var args = JsonDocument.Parse(argumentsJson);
        string Get(string name, string fallback = "") =>
            args.RootElement.TryGetProperty(name, out var v) ? v.GetString() ?? fallback : fallback;

        var action = Get("action").Trim().ToLowerInvariant();
        var path = Get("path");
        var content = Get("content");
        var contentType = Get("contentType", "text/plain");

        if (string.IsNullOrWhiteSpace(path))
            return "No path provided.";

        switch (action)
        {
            case "list":
            {
                var entries = await FilesClient.ListFolderAsync(path, ct);
                return JsonSerializer.Serialize(new
                {
                    action,
                    path,
                    entries = entries.Select(entry => new
                    {
                        Id = entry.Id,
                        IsFolder = entry.IsFolder,
                        Path = entry.Path,
                        Name = entry.Name,
                        ContentType = entry.ContentType,
                        SizeBytes = entry.SizeBytes
                    })
                });
            }
            case "read":
            {
                var readResult = await FilesClient.ReadTextFileAsync(path, ct: ct);
                if (!readResult.Success || readResult.Value is null)
                    return readResult.Error ?? "Could not read that file.";

                var resolved = await FilesClient.ResolvePathAsync(path, ct);
                if (!resolved.Success || resolved.Value is null)
                    return resolved.Error ?? "Could not resolve that file.";

                return JsonSerializer.Serialize(SummarizeFile(resolved.Value, readResult.Value));
            }
            case "tree":
            {
                var treeResult = await FilesClient.ReadStructuredDataAsync(path, ct);
                if (!treeResult.Success || treeResult.Value is null)
                    return treeResult.Error ?? "Could not read that structure.";

                return treeResult.Value;
            }
            case "bundle":
            {
                var bundleResult = await FilesClient.BundleProjectAsync(path, ct);
                if (!bundleResult.Success || bundleResult.Value is null)
                    return bundleResult.Error ?? "Could not bundle that project.";

                return JsonSerializer.Serialize(new
                {
                    action,
                    entryPath = bundleResult.Value.EntryPath,
                    resolvedEntryPath = bundleResult.Value.ResolvedEntryPath,
                    includedFiles = bundleResult.Value.IncludedFiles,
                    warnings = bundleResult.Value.Warnings,
                    totalBytes = bundleResult.Value.TotalBytes,
                    expandedSource = bundleResult.Value.ExpandedSource
                });
            }
            case "write":
            {
                if (string.IsNullOrWhiteSpace(content))
                    return "No content provided.";

                var normalizedContentType = string.IsNullOrWhiteSpace(contentType) ? "text/plain" : contentType;
                var writeResult = await FilesClient.WriteTextFileAsync(path, content, normalizedContentType, ct);
                if (!writeResult.Success || writeResult.Value is null)
                    return writeResult.Error ?? "Could not write that file.";

                return JsonSerializer.Serialize(new
                {
                    action,
                    path = writeResult.Value.Path,
                    Id = writeResult.Value.Id,
                    ContentType = writeResult.Value.ContentType,
                    SizeBytes = writeResult.Value.SizeBytes
                });
            }
            default:
                return "Unknown file action. Use list, read, tree, bundle, or write.";
        }
    }

    private async Task<string> SearchMathReferencesAsync(string argumentsJson, CancellationToken ct)
    {
        using var args = JsonDocument.Parse(argumentsJson);
        var query = args.RootElement.TryGetProperty("query", out var q) ? q.GetString() ?? "" : "";
        if (string.IsNullOrWhiteSpace(query)) return "No query provided.";

        var response = await Http.GetAsync($"/djehuti/api/djelab/search-references?q={Uri.EscapeDataString(query)}", ct);
        if (!response.IsSuccessStatusCode) return $"Search failed with HTTP {(int)response.StatusCode}.";

        using var results = JsonDocument.Parse(await response.Content.ReadAsStringAsync());
        if (results.RootElement.ValueKind != JsonValueKind.Array || results.RootElement.GetArrayLength() == 0)
            return "No matching reference material found.";

        var parts = results.RootElement.EnumerateArray().Select(hit =>
        {
            var title = hit.TryGetProperty("title", out var t) ? t.GetString() : "";
            var content = hit.TryGetProperty("content", out var c) ? c.GetString() : "";
            return $"## {title}\n{content}";
        });
        return string.Join("\n\n", parts);
    }

    private async Task<string> RunSimulationAsync(string argumentsJson, CancellationToken ct)
    {
        using var args = JsonDocument.Parse(argumentsJson);
        string Get(string name, string fallback = "") =>
            args.RootElement.TryGetProperty(name, out var v) ? v.GetString() ?? fallback : fallback;

        var chartType = Get("chartType", "line");
        var xLabel = NormalizeAxisLabel(Get("xLabel", ""), chartType, axis: "x");
        var yLabel = NormalizeAxisLabel(Get("yLabel", ""), chartType, axis: "y");
        var zLabel = NormalizeAxisLabel(Get("zLabel", ""), chartType, axis: "z");
        var source = Get("spinozaSource");
        var projectPath = Get("projectPath");
        var dataPath = Get("dataPath");
        var dataColumns = ReadRequestedColumns(args.RootElement);

        if (string.IsNullOrWhiteSpace(source) && string.IsNullOrWhiteSpace(projectPath))
            return "No spinozaSource or projectPath provided.";

        if (string.IsNullOrWhiteSpace(source) && !string.IsNullOrWhiteSpace(projectPath))
        {
            var bundle = await FilesClient.BundleProjectAsync(projectPath, ct);
            if (!bundle.Success || bundle.Value is null)
                return bundle.Error ?? "Could not bundle that project.";

            source = bundle.Value.ExpandedSource;
        }

        string? runtimeDataJson = null;
        if (!string.IsNullOrWhiteSpace(dataPath))
        {
            var runtimeDataResult = await BuildRuntimeDataJsonAsync(dataPath, dataColumns, ct);
            if (!runtimeDataResult.Success || runtimeDataResult.Value is null)
                return runtimeDataResult.Error ?? "Could not prepare runtime data.";

            runtimeDataJson = runtimeDataResult.Value;
        }

        var outcome = await Actions.RunInNewGraphAsync(chartType, xLabel, yLabel, zLabel, source, runtimeDataJson);
        return outcome.Success
            ? $"Ran successfully in a new {chartType} graph pane; emitted {outcome.PointCount} point(s)."
            : $"The program failed to run: {outcome.Error}";
    }

    private static IReadOnlyList<string> ReadRequestedColumns(JsonElement root)
    {
        if (!root.TryGetProperty("dataColumns", out var value) || value.ValueKind != JsonValueKind.Array)
            return Array.Empty<string>();

        return value
            .EnumerateArray()
            .Select(item => item.GetString()?.Trim())
            .Where(item => !string.IsNullOrWhiteSpace(item))
            .Select(item => item!)
            .ToArray();
    }

    private async Task<FilesResult<string>> BuildRuntimeDataJsonAsync(string dataPath, IReadOnlyList<string> dataColumns, CancellationToken ct)
    {
        var resolved = await FilesClient.ResolvePathAsync(dataPath, ct);
        if (!resolved.Success || resolved.Value is null)
            return FilesResult<string>.Fail(resolved.Error ?? "Could not resolve the data file.");

        if (resolved.Value.IsFolder)
            return FilesResult<string>.Fail("The runtime data path must point to a file, not a folder.");

        var url = await FilesClient.GetDownloadUrlAsync(resolved.Value.Id);
        if (string.IsNullOrWhiteSpace(url))
            return FilesResult<string>.Fail("Could not get a download link for the runtime data file.");

        using var request = new HttpRequestMessage(HttpMethod.Get, url);
        using var response = await Http.SendAsync(request, HttpCompletionOption.ResponseHeadersRead, ct);
        if (!response.IsSuccessStatusCode)
            return FilesResult<string>.Fail($"Could not read the runtime data file (HTTP {(int)response.StatusCode}).");

        await using var stream = await response.Content.ReadAsStreamAsync();
        using var reader = new StreamReader(stream, Encoding.UTF8, detectEncodingFromByteOrderMarks: true);
        var content = await reader.ReadToEndAsync();

        var contentType = (resolved.Value.ContentType ?? "").ToLowerInvariant();
        var extension = Path.GetExtension(resolved.Value.Name).ToLowerInvariant();

        if (contentType.Contains("json") || extension == ".json" || LooksLikeJson(content))
            return BuildJsonRuntimeData(resolved.Value.Path, content, dataColumns);

        if (contentType.Contains("root") || extension == ".root")
        {
            var manifestResult = await FilesClient.TryReadRootManifestTextAsync(dataPath, ct);
            if (!manifestResult.Success || manifestResult.Value is null)
                return FilesResult<string>.Fail(manifestResult.Error ?? "Could not read the ROOT manifest.");

            return BuildJsonRuntimeData(manifestResult.Value.ManifestPath, manifestResult.Value.Content, dataColumns);
        }

        if (contentType.Contains("csv") || extension == ".csv" || LooksLikeCsv(content))
            return BuildCsvRuntimeData(resolved.Value.Path, content, dataColumns);

        return FilesResult<string>.Fail("Runtime data binding currently supports CSV and JSON files.");
    }

    private static FilesResult<string> BuildCsvRuntimeData(string path, string content, IReadOnlyList<string> dataColumns)
    {
        var parsed = CsvText.parse(content);
        var headers = parsed.Headers.Select(header => header.Trim()).ToArray();
        var rows = parsed.Rows.Select(row => row.ToArray()).ToArray();

        if (headers.Length == 0)
            return FilesResult<string>.Fail($"\"{path}\" does not have a CSV header row.");
        if (rows.Length == 0)
            return FilesResult<string>.Fail($"\"{path}\" does not have any data rows.");

        var selectedColumns = ResolveCsvColumns(headers, rows, dataColumns);
        if (!selectedColumns.Success || selectedColumns.Value is null)
            return FilesResult<string>.Fail(selectedColumns.Error ?? "Could not select runtime data columns.");

        if (selectedColumns.Value.Length == 0)
            return FilesResult<string>.Fail("No numeric CSV columns were found. Pick columns explicitly with dataColumns.");

        var extractedRows = new List<double[]>();
        var skippedRows = 0;

        foreach (var row in rows)
        {
            if (TryBuildNumericRow(row, selectedColumns.Value, out var numericRow))
                extractedRows.Add(numericRow);
            else
                skippedRows++;
        }

        if (extractedRows.Count == 0)
            return FilesResult<string>.Fail("No usable numeric rows were found in that CSV file.");

        object runtimeData = selectedColumns.Value.Length == 1
            ? extractedRows.Select(row => row[0]).ToArray()
            : extractedRows.Select(row => row.Cast<double>().ToArray()).ToArray();

        return FilesResult<string>.Ok(JsonSerializer.Serialize(runtimeData));
    }

    private static FilesResult<string> BuildJsonRuntimeData(string path, string content, IReadOnlyList<string> dataColumns)
    {
        try
        {
            using var document = JsonDocument.Parse(content);
            var root = document.RootElement;

            if (root.ValueKind != JsonValueKind.Array)
                return FilesResult<string>.Fail($"\"{path}\" must contain a JSON array for runtime data binding.");

            var items = root.EnumerateArray().ToArray();
            if (items.Length == 0)
                return FilesResult<string>.Fail($"\"{path}\" does not contain any array items.");

            if (items[0].ValueKind == JsonValueKind.Object)
                return BuildJsonObjectRuntimeData(path, items, dataColumns);

            if (items[0].ValueKind == JsonValueKind.Array)
                return BuildJsonArrayRuntimeData(path, items, dataColumns);

            return BuildJsonScalarRuntimeData(path, items, dataColumns);
        }
        catch (JsonException ex)
        {
            return FilesResult<string>.Fail($"Could not parse \"{path}\" as JSON: {ex.Message}");
        }
    }

    private static FilesResult<string> BuildJsonObjectRuntimeData(string path, JsonElement[] items, IReadOnlyList<string> dataColumns)
    {
        var headers = items
            .SelectMany(item => item.EnumerateObject().Select(prop => prop.Name))
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .ToArray();

        var selectedColumns = dataColumns.Count == 0
            ? FilesResult<int[]>.Ok(InferNumericJsonObjectColumns(items, headers).ToArray())
            : ResolveJsonObjectColumns(headers, dataColumns);

        if (!selectedColumns.Success || selectedColumns.Value is null)
            return FilesResult<string>.Fail(selectedColumns.Error ?? "Could not select JSON columns.");

        if (selectedColumns.Value.Length == 0)
            return FilesResult<string>.Fail("No numeric JSON columns were found. Pick columns explicitly with dataColumns.");

        var rows = new List<double[]>();
        foreach (var item in items)
        {
            if (TryBuildNumericJsonObjectRow(item, headers, selectedColumns.Value, out var row))
                rows.Add(row);
        }

        if (rows.Count == 0)
            return FilesResult<string>.Fail($"No usable numeric rows were found in \"{path}\".");

        object runtimeData = selectedColumns.Value.Length == 1
            ? rows.Select(row => row[0]).ToArray()
            : rows.Select(row => row.Cast<double>().ToArray()).ToArray();

        return FilesResult<string>.Ok(JsonSerializer.Serialize(runtimeData));
    }

    private static FilesResult<string> BuildJsonArrayRuntimeData(string path, JsonElement[] items, IReadOnlyList<string> dataColumns)
    {
        var selectedColumns = dataColumns.Count == 0
            ? FilesResult<int[]>.Ok(InferNumericJsonArrayColumns(items).ToArray())
            : ResolveJsonArrayColumns(items, dataColumns);

        if (!selectedColumns.Success || selectedColumns.Value is null)
            return FilesResult<string>.Fail(selectedColumns.Error ?? "Could not select JSON columns.");

        if (selectedColumns.Value.Length == 0)
            return FilesResult<string>.Fail("No numeric JSON columns were found. Pick columns explicitly with dataColumns.");

        var rows = new List<double[]>();
        foreach (var item in items)
        {
            if (TryBuildNumericJsonArrayRow(item, selectedColumns.Value, out var row))
                rows.Add(row);
        }

        if (rows.Count == 0)
            return FilesResult<string>.Fail($"No usable numeric rows were found in \"{path}\".");

        object runtimeData = selectedColumns.Value.Length == 1
            ? rows.Select(row => row[0]).ToArray()
            : rows.Select(row => row.Cast<double>().ToArray()).ToArray();

        return FilesResult<string>.Ok(JsonSerializer.Serialize(runtimeData));
    }

    private static FilesResult<string> BuildJsonScalarRuntimeData(string path, JsonElement[] items, IReadOnlyList<string> dataColumns)
    {
        var values = new List<double>();
        foreach (var item in items)
        {
            if (TryReadNumericJsonValue(item, out var value))
                values.Add(value);
        }

        if (values.Count == 0)
            return FilesResult<string>.Fail($"No numeric values were found in \"{path}\".");

        return FilesResult<string>.Ok(JsonSerializer.Serialize(values));
    }

    private static FilesResult<int[]> ResolveCsvColumns(string[] headers, string[][] rows, IReadOnlyList<string> dataColumns)
    {
        if (dataColumns.Count == 0)
            return FilesResult<int[]>.Ok(InferNumericCsvColumns(headers, rows).ToArray());

        var resolved = new List<int>();
        foreach (var column in dataColumns)
        {
            if (int.TryParse(column, out var index))
            {
                if (index < 0 || index >= headers.Length)
                    return FilesResult<int[]>.Fail($"CSV column index {index} is out of range for {headers.Length} header(s).");
                if (!resolved.Contains(index))
                    resolved.Add(index);
                continue;
            }

            var match = Array.FindIndex(headers, header => string.Equals(header, column, StringComparison.OrdinalIgnoreCase));
            if (match < 0)
                return FilesResult<int[]>.Fail($"Could not find CSV column \"{column}\".");

            if (!resolved.Contains(match))
                resolved.Add(match);
        }

        return FilesResult<int[]>.Ok(resolved.ToArray());
    }

    private static FilesResult<int[]> ResolveJsonObjectColumns(string[] headers, IReadOnlyList<string> dataColumns)
    {
        var resolved = new List<int>();
        foreach (var column in dataColumns)
        {
            var match = Array.FindIndex(headers, header => string.Equals(header, column, StringComparison.OrdinalIgnoreCase));
            if (match < 0)
                return FilesResult<int[]>.Fail($"Could not find JSON field \"{column}\".");

            if (!resolved.Contains(match))
                resolved.Add(match);
        }

        return FilesResult<int[]>.Ok(resolved.ToArray());
    }

    private static FilesResult<int[]> ResolveJsonArrayColumns(JsonElement[] items, IReadOnlyList<string> dataColumns)
    {
        if (!items.All(item => item.ValueKind == JsonValueKind.Array))
            return FilesResult<int[]>.Fail("JSON data must be a consistent array-of-arrays shape.");

        var width = items.Max(item => item.GetArrayLength());
        var resolved = new List<int>();
        foreach (var column in dataColumns)
        {
            if (!int.TryParse(column, out var index))
                return FilesResult<int[]>.Fail("JSON arrays can only be selected by zero-based index.");
            if (index < 0 || index >= width)
                return FilesResult<int[]>.Fail($"JSON column index {index} is out of range for arrays with width {width}.");
            if (!resolved.Contains(index))
                resolved.Add(index);
        }

        return FilesResult<int[]>.Ok(resolved.ToArray());
    }

    private static List<int> InferNumericCsvColumns(string[] headers, string[][] rows)
    {
        var result = new List<int>();
        for (var columnIndex = 0; columnIndex < headers.Length; columnIndex++)
        {
            var sawValue = false;
            var numeric = true;
            foreach (var row in rows)
            {
                if (columnIndex >= row.Length)
                {
                    numeric = false;
                    break;
                }

                var cell = row[columnIndex].Trim();
                if (string.IsNullOrWhiteSpace(cell) || !TryParseNumericCell(cell, out _))
                {
                    numeric = false;
                    break;
                }

                sawValue = true;
            }

            if (numeric && sawValue)
                result.Add(columnIndex);
        }

        return result;
    }

    private static List<int> InferNumericJsonObjectColumns(JsonElement[] items, string[] headers)
    {
        var result = new List<int>();
        for (var columnIndex = 0; columnIndex < headers.Length; columnIndex++)
        {
            var sawValue = false;
            var numeric = true;

            foreach (var item in items)
            {
                if (!item.TryGetProperty(headers[columnIndex], out var property) || !TryReadNumericJsonValue(property, out _))
                {
                    numeric = false;
                    break;
                }

                sawValue = true;
            }

            if (numeric && sawValue)
                result.Add(columnIndex);
        }

        return result;
    }

    private static List<int> InferNumericJsonArrayColumns(JsonElement[] items)
    {
        if (!items.All(item => item.ValueKind == JsonValueKind.Array))
            return new List<int>();

        var width = items.Max(item => item.GetArrayLength());
        var result = new List<int>();
        for (var columnIndex = 0; columnIndex < width; columnIndex++)
        {
            var sawValue = false;
            var numeric = true;

            foreach (var item in items)
            {
                var row = item.EnumerateArray().ToArray();
                if (columnIndex >= row.Length || !TryReadNumericJsonValue(row[columnIndex], out _))
                {
                    numeric = false;
                    break;
                }

                sawValue = true;
            }

            if (numeric && sawValue)
                result.Add(columnIndex);
        }

        return result;
    }

    private static bool TryBuildNumericRow(string[] row, IReadOnlyList<int> selectedColumns, out double[] numericRow)
    {
        var values = new double[selectedColumns.Count];
        for (var i = 0; i < selectedColumns.Count; i++)
        {
            var index = selectedColumns[i];
            if (index >= row.Length || !TryParseNumericCell(row[index].Trim(), out var value))
            {
                numericRow = Array.Empty<double>();
                return false;
            }

            values[i] = value;
        }

        numericRow = values;
        return true;
    }

    private static bool TryBuildNumericJsonObjectRow(JsonElement item, string[] headers, IReadOnlyList<int> selectedColumns, out double[] numericRow)
    {
        var values = new double[selectedColumns.Count];
        for (var i = 0; i < selectedColumns.Count; i++)
        {
            var index = selectedColumns[i];
            if (index >= headers.Length || !item.TryGetProperty(headers[index], out var property) || !TryReadNumericJsonValue(property, out var value))
            {
                numericRow = Array.Empty<double>();
                return false;
            }

            values[i] = value;
        }

        numericRow = values;
        return true;
    }

    private static bool TryBuildNumericJsonArrayRow(JsonElement item, IReadOnlyList<int> selectedColumns, out double[] numericRow)
    {
        var row = item.EnumerateArray().ToArray();
        var values = new double[selectedColumns.Count];
        for (var i = 0; i < selectedColumns.Count; i++)
        {
            var index = selectedColumns[i];
            if (index >= row.Length || !TryReadNumericJsonValue(row[index], out var value))
            {
                numericRow = Array.Empty<double>();
                return false;
            }

            values[i] = value;
        }

        numericRow = values;
        return true;
    }

    private static bool TryReadNumericJsonValue(JsonElement element, out double value)
    {
        switch (element.ValueKind)
        {
            case JsonValueKind.Number:
                value = element.GetDouble();
                return true;
            case JsonValueKind.True:
                value = 1;
                return true;
            case JsonValueKind.False:
                value = 0;
                return true;
            default:
                value = 0;
                return false;
        }
    }

    private static bool TryParseNumericCell(string cell, out double value)
    {
        if (double.TryParse(cell, System.Globalization.NumberStyles.Float, System.Globalization.CultureInfo.InvariantCulture, out value))
            return true;

        if (bool.TryParse(cell, out var boolValue))
        {
            value = boolValue ? 1 : 0;
            return true;
        }

        value = 0;
        return false;
    }

    private async Task<string> ValidateSpinozaAsync(string argumentsJson, CancellationToken ct)
    {
        using var args = JsonDocument.Parse(argumentsJson);
        var source = args.RootElement.TryGetProperty("spinozaSource", out var sourceValue) ? sourceValue.GetString() ?? "" : "";
        if (string.IsNullOrWhiteSpace(source))
            return "No spinozaSource provided.";

        var report = Djehuti.DjeLab.Dsl.Preflight.validate(source);
        return JsonSerializer.Serialize(new
        {
            report.CanRun,
            report.Parsed,
            report.Summary,
            issues = report.Issues.Select(issue => new
            {
                severity = issue.Severity.ToString().ToLowerInvariant(),
                message = issue.Message
            })
        });
    }

    private static string NormalizeAxisLabel(string? label, string chartType, string axis)
    {
        var trimmed = string.IsNullOrWhiteSpace(label) ? "" : label.Trim();
        if (!IsGenericAxisLabel(trimmed)) return trimmed;

        return chartType switch
        {
            "surface" => axis switch
            {
                "x" => "x position",
                "y" => "y position",
                _ => "height"
            },
            "scatter3d" => axis switch
            {
                "x" => "x position",
                "y" => "y position",
                _ => "height"
            },
            _ => axis switch
            {
                "x" => "input",
                "y" => "value",
                _ => "value"
            }
        };
    }

    private static bool IsGenericAxisLabel(string label) =>
        string.IsNullOrWhiteSpace(label) ||
        label is "x" or "y" or "z" or "X" or "Y" or "Z" or "x-axis" or "y-axis" or "z-axis";

    private static object SummarizeFile(DjeLabFileEntry entry, string content)
    {
        var kind = DetectKind(entry, content);
        var preview = content.Length > 20000 ? content[..20000] : content;
        var truncated = entry.SizeBytes is long size && size > content.Length;

        return kind switch
        {
            "json" => SummarizeJson(entry, content, preview, truncated),
            "csv" => SummarizeCsv(entry, content, preview, truncated),
            _ => new
            {
                kind = "text",
                Path = entry.Path,
                ContentType = entry.ContentType,
                SizeBytes = entry.SizeBytes,
                preview,
                truncated = truncated || content.Length > preview.Length
            }
        };
    }

    private static object SummarizeJson(DjeLabFileEntry entry, string content, string preview, bool truncated)
    {
        try
        {
            using var doc = JsonDocument.Parse(content);
            if (doc.RootElement.ValueKind == JsonValueKind.Array)
            {
                var sample = doc.RootElement.EnumerateArray().Take(5).Select(item => item.ValueKind == JsonValueKind.Object
                    ? item.EnumerateObject().Take(20).ToDictionary(prop => prop.Name, prop => prop.Value.ToString())
                    : new Dictionary<string, string> { ["value"] = item.ToString() }).ToArray();

                return new
                {
                    kind = "json-array",
                    Path = entry.Path,
                    ContentType = entry.ContentType,
                    SizeBytes = entry.SizeBytes,
                    count = doc.RootElement.GetArrayLength(),
                    sample,
                    preview = preview.Length == content.Length ? preview : preview + "\n...",
                    truncated
                };
            }

            if (doc.RootElement.ValueKind == JsonValueKind.Object)
            {
                return new
                {
                    kind = "json-object",
                    Path = entry.Path,
                    ContentType = entry.ContentType,
                    SizeBytes = entry.SizeBytes,
                    keys = doc.RootElement.EnumerateObject().Select(prop => prop.Name).Take(50).ToArray(),
                    preview = preview.Length == content.Length ? preview : preview + "\n...",
                    truncated
                };
            }
        }
        catch (JsonException)
        {
            // Fall through to generic text summary.
        }

        return new
        {
            kind = "json-text",
            Path = entry.Path,
            ContentType = entry.ContentType,
            SizeBytes = entry.SizeBytes,
            preview = preview.Length == content.Length ? preview : preview + "\n...",
            truncated
        };
    }

    private static object SummarizeCsv(DjeLabFileEntry entry, string content, string preview, bool truncated)
    {
        var parsed = CsvText.parse(content);
        var headers = parsed.Headers.ToArray();
        var sampleRows = parsed.Rows.Take(5).Select(row => row.ToArray()).ToArray();

        return new
        {
            kind = "csv",
            Path = entry.Path,
            ContentType = entry.ContentType,
            SizeBytes = entry.SizeBytes,
            headers,
            rowCount = parsed.Rows.Count(),
            sampleRows,
            preview = preview.Length == content.Length ? preview : preview + "\n...",
            truncated
        };
    }

    private static string DetectKind(DjeLabFileEntry entry, string content)
    {
        var type = (entry.ContentType ?? "").ToLowerInvariant();
        if (type.Contains("json")) return "json";
        if (type.Contains("csv") || entry.Path.EndsWith(".csv", StringComparison.OrdinalIgnoreCase)) return "csv";
        if (entry.Path.EndsWith(".json", StringComparison.OrdinalIgnoreCase)) return "json";
        if (LooksLikeJson(content)) return "json";
        if (LooksLikeCsv(content)) return "csv";
        return "text";
    }

    private static bool LooksLikeJson(string content)
    {
        var trimmed = content.TrimStart();
        return trimmed.StartsWith("{") || trimmed.StartsWith("[");
    }

    private static bool LooksLikeCsv(string content)
    {
        var parsed = CsvText.parse(content);
        return parsed.Headers.Count() >= 2 && parsed.Rows.Count() >= 1;
    }

    private async Task Send()
    {
        var text = _input.Trim();
        if (string.IsNullOrEmpty(text) || _sending) return;

        _input = "";
        _error = null;
        var history = _turns.ToList();
        _turns.Add(new ChatTurn { Role = "user", Content = text });
        _sending = true;
        _sendCts?.Dispose();
        _sendCts = new CancellationTokenSource();
        StateHasChanged();

        try
        {
            await TryInvokeJsAsync("resetTextareaHeight", _inputRef);
            var reply = await ChatClient.AskAsync(_apiKey, _model, history, text, ToolHandlers, _sendCts.Token);
            LogMathDelimiterDiagnostics(reply);
            _turns.Add(new ChatTurn { Role = "assistant", Content = reply });
            await HistoryStore.SaveTurnsAsync(_turns);
        }
        catch (OperationCanceledException)
        {
            _error = "Stopped.";
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _sending = false;
            _sendCts?.Dispose();
            _sendCts = null;
        }
    }

    private Task StopSendAsync()
    {
        _sendCts?.Cancel();
        return Task.CompletedTask;
    }

    private async Task ClearChat()
    {
        _turns.Clear();
        _error = null;
        await HistoryStore.ClearAsync();
    }

    // Diagnostic only -- routes to the browser devtools console (Console.
    // WriteLine does this in Blazor WASM). If math delimiters ever silently
    // fail to normalize again, this shows the actual raw text directly
    // rather than needing another screenshot round-trip to guess from.
    private static void LogMathDelimiterDiagnostics(string reply)
    {
        var stillHasRawDelimiters = reply.Contains(@"\(") || reply.Contains(@"\[");
        if (stillHasRawDelimiters)
        {
            var preview = reply.Length > 200 ? reply[..200] + "…" : reply;
            Console.WriteLine($"[DjeLab] Reply still contains raw \\( or \\[ after normalization. Preview: {preview}");
        }
    }
