@implements IDisposable
@inject DjeLabFilesClient FilesClient
@inject HttpClient Http
@inject IJSRuntime JS
@inject WorkspaceActions Actions

<div class="files-pane">
    @if (_checkingAuth)
    {
        <div class="files-empty">Loading…</div>
    }
    else if (!_signedIn)
    {
        <div class="files-empty">
            <p>Sign in to use file storage.</p>
            <a class="files-signin-link" href="/">Sign in</a>
        </div>
    }
    else
    {
        <div class="files-toolbar">
            <div class="files-breadcrumb">
                @foreach (var crumb in Breadcrumbs())
                {
                    <button type="button" class="files-breadcrumb-segment" @onclick="() => NavigateTo(crumb.Path)">@crumb.Label</button>
                    <span class="files-breadcrumb-sep">/</span>
                }
            </div>
            <div class="files-toolbar-actions">
                <button type="button" class="files-action-btn" @onclick="ShowNewFolderInput" disabled="@_uploading">New Folder</button>
                <InputFile OnChange="OnFileSelected" class="files-upload-input" disabled="@_uploading" />
            </div>
        </div>

        @if (_usage is not null)
        {
            var pct = _usage.QuotaBytes > 0 ? Math.Min(100.0, 100.0 * _usage.UsedBytes / _usage.QuotaBytes) : 0.0;
            <div class="files-usage-bar">
                <div class="files-usage-track"><div class="files-usage-fill" style="width: @(pct.ToString("F1"))%"></div></div>
                <span class="files-usage-label">@FormatBytes(_usage.UsedBytes) / @FormatBytes(_usage.QuotaBytes) &middot; @_usage.TierName</span>
            </div>
        }

        @if (_showNewFolder)
        {
            <form class="files-new-folder-row" @onsubmit="SubmitNewFolder">
                <input class="files-new-folder-input" @bind="_newFolderName" @bind:event="oninput" placeholder="Folder name" />
                <button type="submit" class="files-action-btn">Create</button>
                <button type="button" class="files-action-btn" @onclick="() => _showNewFolder = false">Cancel</button>
            </form>
        }

        @if (_error is not null)
        {
            <div class="files-error">@_error</div>
        }

        @if (_selectedPath is not null)
        {
            <div class="files-preview-panel">
                <div class="files-preview-header">
                    <div class="files-preview-title">
                        <span>@_selectedName</span>
                        <span class="files-preview-path">@_selectedPath</span>
                    </div>
                    <div class="files-preview-actions">
                        <button type="button" class="files-action-btn" @onclick="ReloadSelectedAsync" disabled="@_selectedLoading">Reload</button>
                        <button type="button" class="files-action-btn" @onclick="SaveSelectedAsync" disabled="@(!_selectedEditable || _selectedLoading || _selectedTruncated)">Save</button>
                        <button type="button" class="files-action-btn" @onclick="ClearSelectedFile">Close</button>
                    </div>
                </div>
                <div class="files-preview-meta">
                    <span>@(_selectedContentType ?? "text/plain")</span>
                    @if (_selectedSizeBytes is long sizeBytes)
                    {
                        <span>&middot; @FormatBytes(sizeBytes)</span>
                    }
                    @if (_selectedTruncated)
                    {
                        <span class="files-preview-warning">&middot; preview only</span>
                    }
                </div>
                <textarea class="files-preview-editor"
                          @bind="_selectedContent"
                          @bind:event="oninput"
                          disabled="@(!_selectedEditable || _selectedLoading || _selectedTruncated)"></textarea>
                @if (_selectedMessage is not null)
                {
                    <div class="files-preview-note">@_selectedMessage</div>
                }
            </div>
        }

        <div class="files-list">
            @if (_loading)
            {
                <div class="files-empty">Loading…</div>
            }
            else if (_entries.Count == 0)
            {
                <div class="files-empty">This folder is empty.</div>
            }
            else
            {
                @foreach (var entry in _entries)
                {
                    <div class="files-row">
                        @if (entry.IsFolder)
                        {
                            <button type="button" class="files-row-name files-row-folder" @onclick="() => NavigateTo(entry.Path)">
                                <span class="files-row-icon">📁</span> @entry.Name
                            </button>
                        }
                        else
                        {
                            <button type="button" class="files-row-name files-row-file" @onclick="() => OpenFile(entry)">
                                <span class="files-row-icon">📄</span> @entry.Name
                            </button>
                            <span class="files-row-size">@FormatBytes(entry.SizeBytes ?? 0)</span>
                        }
                        <span class="files-row-actions">
                            @if (!entry.IsFolder)
                            {
                                <button type="button" class="files-row-btn" title="Download" @onclick="() => Download(entry)">⬇</button>
                            }
                            <button type="button" class="files-row-btn files-row-btn-danger" title="Delete" @onclick="() => Delete(entry)">✕</button>
                        </span>
                    </div>
                }
            }
        </div>
    }
</div>

@code {
    // Browser-memory buffering constraint for a single upload (separate from
    // the tier storage quota, which the server enforces) -- IBrowserFile
    // reads the whole file into memory before it can be streamed to S3, so
    // an unbounded per-file size would risk hanging the tab on something huge.
    private const long MaxSingleFileBytes = 100L * 1024 * 1024;

    private bool _checkingAuth = true;
    private bool _signedIn;
    private bool _loading = true;
    private bool _uploading;
    private bool _showNewFolder;
    private string _currentPath = "/";
    private string _newFolderName = "";
    private string? _error;
    private List<DjeLabFileEntry> _entries = new();
    private StorageUsage? _usage;
    private string? _selectedPath;
    private string? _selectedName;
    private string? _selectedContentType;
    private long? _selectedSizeBytes;
    private bool _selectedEditable;
    private bool _selectedTruncated;
    private bool _selectedLoading;
    private string _selectedContent = "";
    private string? _selectedMessage;
    private const long MaxEditableFileBytes = 1024L * 1024;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var response = await Http.GetAsync("/djehuti/api/auth/me");
            // A bare status-code check isn't enough: in local dev (no API
            // proxy configured), an unmapped request falls through to a 200
            // HTML page rather than a real 401, which would otherwise read
            // as "signed in". Require the body to actually parse as the
            // expected shape, matching Home.razor's same defensive check.
            _signedIn = response.IsSuccessStatusCode
                && (await response.Content.ReadFromJsonAsync<MeResponse>()) is not null;
        }
        catch
        {
            _signedIn = false;
        }
        finally
        {
            _checkingAuth = false;
        }

        Actions.FilesChangedRequested += HandleFilesChangedRequested;
        if (_signedIn) await RefreshAsync();
    }

    private IEnumerable<(string Label, string Path)> Breadcrumbs()
    {
        yield return ("Home", "/");
        if (_currentPath == "/") yield break;

        var accPath = "";
        foreach (var segment in _currentPath.Trim('/').Split('/'))
        {
            accPath += "/" + segment;
            yield return (segment, accPath);
        }
    }

    private async Task NavigateTo(string path)
    {
        _currentPath = path;
        _showNewFolder = false;
        _error = null;
        ClearSelectedFile();
        await RefreshAsync();
    }

    private async Task RefreshAsync()
    {
        _loading = true;
        StateHasChanged();
        try
        {
            _entries = await FilesClient.ListFolderAsync(_currentPath);
            _usage = await FilesClient.GetUsageAsync();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _loading = false;
            StateHasChanged();
        }
    }

    private void ShowNewFolderInput()
    {
        _showNewFolder = true;
        _newFolderName = "";
        _error = null;
    }

    private async Task SubmitNewFolder()
    {
        var name = _newFolderName.Trim();
        if (string.IsNullOrWhiteSpace(name)) return;

        var result = await FilesClient.CreateFolderAsync(_currentPath, name);
        if (!result.Success)
        {
            _error = result.Error;
            return;
        }

        _showNewFolder = false;
        _newFolderName = "";
        Actions.AppendConsole("Files", $"Created folder {name} in {_currentPath}.");
        await RefreshAsync();
    }

    private async Task OnFileSelected(InputFileChangeEventArgs e)
    {
        var file = e.File;
        _uploading = true;
        _error = null;
        StateHasChanged();

        try
        {
            if (file.Size > MaxSingleFileBytes)
            {
                _error = $"{file.Name} is larger than the {FormatBytes(MaxSingleFileBytes)} per-file limit.";
                return;
            }

            var contentType = string.IsNullOrWhiteSpace(file.ContentType) ? "application/octet-stream" : file.ContentType;
            Actions.AppendConsole("Files", $"Uploading {file.Name} into {_currentPath}.");

            var urlResult = await FilesClient.RequestUploadUrlAsync(_currentPath, file.Name, contentType, file.Size);
            if (!urlResult.Success)
            {
                _error = urlResult.Error;
                return;
            }

            await using (var stream = file.OpenReadStream(MaxSingleFileBytes))
            {
                await FilesClient.UploadToPresignedUrlAsync(urlResult.Value!.PresignedUrl, stream, contentType);
            }

            var confirmResult = await FilesClient.ConfirmUploadAsync(urlResult.Value!.FileId, _currentPath, file.Name, contentType);
            if (!confirmResult.Success)
            {
                _error = confirmResult.Error;
                return;
            }

            await RefreshAsync();
            await OpenFile(confirmResult.Value!);
            Actions.AppendConsole("Files", $"Uploaded {file.Name} to {_currentPath}.");
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _uploading = false;
            StateHasChanged();
        }
    }

    private async Task Download(DjeLabFileEntry entry)
    {
        var url = await FilesClient.GetDownloadUrlAsync(entry.Id);
        if (url is null)
        {
            _error = "Could not get a download link.";
            return;
        }
        await JS.InvokeVoidAsync("open", url, "_blank");
    }

    private async Task Delete(DjeLabFileEntry entry)
    {
        var message = entry.IsFolder
            ? $"Delete the folder \"{entry.Name}\" and everything inside it?"
            : $"Delete \"{entry.Name}\"?";
        var confirmed = await JS.InvokeAsync<bool>("confirm", message);
        if (!confirmed) return;

        var ok = await FilesClient.DeleteAsync(entry.Id);
        if (!ok)
        {
            _error = "Could not delete that.";
            return;
        }
        Actions.AppendConsole("Files", entry.IsFolder
            ? $"Deleted folder {entry.Path}."
            : $"Deleted file {entry.Path}.");
        await RefreshAsync();

        if (string.Equals(_selectedPath, entry.Path, StringComparison.OrdinalIgnoreCase))
            ClearSelectedFile();
    }

    private async Task OpenFile(DjeLabFileEntry entry)
    {
        _selectedLoading = true;
        _selectedMessage = null;
        StateHasChanged();

        try
        {
            _selectedPath = entry.Path;
            _selectedName = entry.Name;
            _selectedContentType = entry.ContentType;
            _selectedSizeBytes = entry.SizeBytes;
            _selectedEditable = IsLikelyTextFile(entry);

            if (_selectedEditable)
            {
                var readResult = await FilesClient.ReadTextFileAsync(entry.Path, maxBytes: MaxEditableFileBytes);
                if (!readResult.Success || readResult.Value is null)
                {
                    _selectedMessage = readResult.Error ?? "Could not read that file.";
                    _selectedContent = "";
                    _selectedTruncated = false;
                    Actions.ClearActiveFileContext();
                    return;
                }

                _selectedContent = readResult.Value;
                _selectedTruncated = entry.SizeBytes is long size && size > MaxEditableFileBytes;
                Actions.SetActiveFileContext(BuildSnapshot(entry.Path, entry.Name, entry.ContentType, entry.SizeBytes, _selectedEditable, _selectedTruncated, _selectedContent));
                _selectedMessage = _selectedTruncated
                    ? "This file is large enough that only a preview was loaded. Save is disabled until we add a full-file editor path."
                    : "Loaded into the editor.";
                Actions.AppendConsole("Files", $"Opened {_selectedPath} for editing{(_selectedTruncated ? " (preview)" : "")}.");
            }
            else
            {
                var previewResult = await FilesClient.ReadTextPreviewAsync(entry.Path, maxBytes: 128 * 1024);
                if (!previewResult.Success || previewResult.Value is null)
                {
                    _selectedMessage = previewResult.Error ?? "Could not read that file.";
                    _selectedContent = "";
                    _selectedTruncated = false;
                    Actions.ClearActiveFileContext();
                    return;
                }

                _selectedContent = previewResult.Value.Content;
                _selectedTruncated = previewResult.Value.Truncated;
                _selectedMessage = "This file is preview-only.";
                Actions.SetActiveFileContext(BuildSnapshot(entry.Path, entry.Name, entry.ContentType, entry.SizeBytes, _selectedEditable, _selectedTruncated, _selectedContent));
                Actions.AppendConsole("Files", $"Previewed {_selectedPath}{(_selectedTruncated ? " (truncated)" : "")}.");
            }
        }
        catch (Exception ex)
        {
            _selectedMessage = ex.Message;
            Actions.ClearActiveFileContext();
        }
        finally
        {
            _selectedLoading = false;
            StateHasChanged();
        }
    }

    private async Task ReloadSelectedAsync()
    {
        if (_selectedPath is null)
            return;

        var entry = _entries.FirstOrDefault(item => string.Equals(item.Path, _selectedPath, StringComparison.OrdinalIgnoreCase));
        if (entry is null)
            return;

        await OpenFile(entry);
    }

    private async Task SaveSelectedAsync()
    {
        if (!_selectedEditable || _selectedTruncated || string.IsNullOrWhiteSpace(_selectedPath))
            return;

        _selectedLoading = true;
        _selectedMessage = null;
        StateHasChanged();

        try
        {
            var contentType = string.IsNullOrWhiteSpace(_selectedContentType) ? "text/plain" : _selectedContentType;
            var result = await FilesClient.WriteTextFileAsync(_selectedPath, _selectedContent, contentType);
            if (!result.Success || result.Value is null)
            {
                _selectedMessage = result.Error ?? "Could not save that file.";
                return;
            }

            _selectedPath = result.Value.Path;
            _selectedName = result.Value.Name;
            _selectedContentType = result.Value.ContentType;
            _selectedSizeBytes = result.Value.SizeBytes;
            _selectedMessage = $"Saved to {_selectedPath}.";
            Actions.SetActiveFileContext(BuildSnapshot(result.Value.Path, result.Value.Name, result.Value.ContentType, result.Value.SizeBytes, _selectedEditable, false, _selectedContent));
            Actions.AppendConsole("Files", $"Saved {_selectedPath}.");
            Actions.NotifyFilesChanged();
            await RefreshAsync();
        }
        catch (Exception ex)
        {
            _selectedMessage = ex.Message;
        }
        finally
        {
            _selectedLoading = false;
            StateHasChanged();
        }
    }

    private void ClearSelectedFile()
    {
        _selectedPath = null;
        _selectedName = null;
        _selectedContentType = null;
        _selectedSizeBytes = null;
        _selectedEditable = false;
        _selectedTruncated = false;
        _selectedLoading = false;
        _selectedContent = "";
        _selectedMessage = null;
        Actions.ClearActiveFileContext();
    }

    private void HandleFilesChangedRequested()
    {
        _ = InvokeAsync(RefreshAsync);
    }

    private static ActiveFileContextSnapshot BuildSnapshot(
        string path,
        string name,
        string? contentType,
        long? sizeBytes,
        bool editable,
        bool truncated,
        string content)
    {
        var preview = content.Length > 2000 ? content[..2000] + "…" : content;
        return new ActiveFileContextSnapshot(path, name, contentType, sizeBytes, editable, truncated, preview);
    }

    private static bool IsLikelyTextFile(DjeLabFileEntry entry)
    {
        var contentType = (entry.ContentType ?? "").ToLowerInvariant();
        var extension = Path.GetExtension(entry.Name).ToLowerInvariant();

        if (contentType.StartsWith("text/"))
            return true;

        return extension is ".txt" or ".md" or ".csv" or ".json" or ".xml" or ".yml" or ".yaml" or ".fs" or ".fsx" or ".cs" or ".razor" or ".js" or ".ts" or ".css" or ".html" or ".htm" or ".sql" or ".jsonl";
    }

    private static string FormatBytes(long bytes)
    {
        string[] units = { "B", "KB", "MB", "GB" };
        double size = bytes;
        var unitIndex = 0;
        while (size >= 1024 && unitIndex < units.Length - 1)
        {
            size /= 1024;
            unitIndex++;
        }
        return $"{size:F1} {units[unitIndex]}";
    }

    private sealed class MeResponse
    {
        public string? DisplayName { get; set; }
        public string? Email { get; set; }
    }

    public void Dispose()
    {
        Actions.FilesChangedRequested -= HandleFilesChangedRequested;
    }
}
